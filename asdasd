- name: Install cosign
  uses: sigstore/cosign-installer@v3

- name: Download, verify, and install Trivy
  env:
    TRIVY_VERSION: "0.70.0"
  run: |
    set -euo pipefail

    TARBALL="trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz"
    BUNDLE="${TARBALL}.sigstore.json"

    curl -fsSLO "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/${TARBALL}"
    curl -fsSLO "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/${BUNDLE}"

    cosign verify-blob-attestation "${TARBALL}" \
      --bundle "${BUNDLE}" \
      --certificate-oidc-issuer="https://token.actions.githubusercontent.com" \
      --certificate-identity "https://github.com/aquasecurity/trivy/.github/workflows/reusable-release.yaml@refs/tags/v${TRIVY_VERSION}"

    tar -xzf "${TARBALL}"
    chmod +x ./trivy
    sudo mv ./trivy /usr/local/bin/trivy

    trivy --version

- name: Scan image in ACR using JFrog-hosted Trivy DBs
  env:
    TRIVY_DB_REPOSITORY: jfrog.example.com/ghcr-remote/aquasecurity/trivy-db
    TRIVY_JAVA_DB_REPOSITORY: jfrog.example.com/ghcr-remote/aquasecurity/trivy-java-db
    TRIVY_CHECKS_BUNDLE_REPOSITORY: jfrog.example.com/ghcr-remote/aquasecurity/trivy-checks
  run: |
    trivy image \
      --severity HIGH,CRITICAL \
      --vuln-type os,library \
      --exit-code 1 \
      "${ACR_LOGIN_SERVER}/${IMAGE_NAME}:${IMAGE_TAG}"
