name: "Generate Team Landing Zone tfvars"

on:
  issues:
    types: [opened, edited]

permissions:
  contents: write
  pull-requests: write
  issues: write

jobs:
  generate-tfvars:
    # Only run for issues with the auto-tfvars label (set by the issue template)
    if: contains(github.event.issue.labels.*.name, 'auto-tfvars')
    runs-on: ubuntu-latest

    steps:
      # ── 1. Checkout the repo ───────────────────────────────
      - name: Checkout
        uses: actions/checkout@v4

      # ── 2. Set up Python ───────────────────────────────────
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      # ── 3. Generate the tfvars file ────────────────────────
      - name: Generate tfvars
        id: gen
        env:
          ISSUE_BODY: ${{ github.event.issue.body }}
        run: python scripts/generate_tfvars.py

      # ── 4. Create a PR with the generated file ─────────────
      - name: Create Pull Request
        id: pr
        uses: peter-evans/create-pull-request@v6
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          branch: "lz-onboard/${{ steps.gen.outputs.team_name }}/${{ steps.gen.outputs.environment }}"
          commit-message: |
            feat(lz): onboard ${{ steps.gen.outputs.team_name }} (${{ steps.gen.outputs.environment }})

            Auto-generated from issue #${{ github.event.issue.number }}
          title: "🚀 Onboard: ${{ steps.gen.outputs.team_name }} → ${{ steps.gen.outputs.environment }}"
          body: |
            ## Auto-generated Landing Zone tfvars

            | Field | Value |
            |-------|-------|
            | **Team** | `${{ steps.gen.outputs.team_name }}` |
            | **Environment** | `${{ steps.gen.outputs.environment }}` |
            | **Source Issue** | #${{ github.event.issue.number }} |
            | **tfvars path** | `${{ steps.gen.outputs.tfvars_path }}` |

            ### What to review
            - [ ] Verify resource quotas match the team's expected workload
            - [ ] Confirm Pod Identity services are correct (least-privilege)
            - [ ] Check network policy defaults
            - [ ] Validate compliance framework selection
            - [ ] Ensure tags are accurate for cost attribution

            ---
            > Merging this PR will make the tfvars available for the next `terraform apply`.
            > The pipeline will pick up `${{ steps.gen.outputs.tfvars_path }}` automatically.
          labels: |
            landing-zone
            auto-generated
          reviewers: |
            platform-team

      # ── 5. Comment back on the issue with the PR link ──────
      - name: Comment on issue
        if: steps.pr.outputs.pull-request-number
        uses: peter-evans/create-or-update-comment@v4
        with:
          issue-number: ${{ github.event.issue.number }}
          body: |
            ✅ **tfvars generated successfully!**

            📄 File: `${{ steps.gen.outputs.tfvars_path }}`
            🔗 Review PR: #${{ steps.pr.outputs.pull-request-number }}

            The platform team has been tagged for review. Once the PR is approved and merged, your landing zone will be provisioned on the next pipeline run.

      # ── 6. Handle failure ──────────────────────────────────
      - name: Comment on failure
        if: failure()
        uses: peter-evans/create-or-update-comment@v4
        with:
          issue-number: ${{ github.event.issue.number }}
          body: |
            ❌ **tfvars generation failed.**

            The workflow encountered an error. Please check the [workflow run](${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}) for details.

            Common issues:
            - Team name contains invalid characters (use lowercase alphanumeric + hyphens)
            - Required fields are missing

            cc @platform-team
