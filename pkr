source "azure-arm" "rhel9" {
  # ---- Auth: federated via az CLI session established by azure/login@v2 ----
  use_azure_cli_auth = true
  subscription_id    = var.subscription_id
  tenant_id          = var.tenant_id
  client_id          = var.client_id

  # ---- GovCloud ----
  cloud_environment_name = "USGovernment"

  # ---- Source marketplace image ----
  os_type         = "Linux"
  image_publisher = var.image_publisher
  image_offer     = var.image_offer
  image_sku       = var.image_sku
  image_version   = var.image_src_ver

  # ---- Build infra: existing RG + existing VNet (private) ----
  build_resource_group_name         = var.build_resource_group
  virtual_network_name              = var.vnet_name
  virtual_network_resource_group_name = var.vnet_resource_group
  virtual_network_subnet_name       = var.subnet_name
  private_virtual_network_with_public_ip = false   # no public IP
  vm_size                           = var.vm_size

  # ---- Destination: Compute Gallery (SIG) ----
  managed_image_name                = "${var.image_definition_name}-${var.image_version}"
  managed_image_resource_group_name = var.build_resource_group

  shared_image_gallery_destination {
    resource_group       = var.gallery_resource_group
    gallery_name         = var.gallery_name
    image_name           = var.image_definition_name
    image_version        = var.image_version
    replication_regions  = var.replication_regions
    storage_account_type = "Premium_LRS"
  }

  # ---- SSH: Packer generates a one-time keypair, uses it, throws it away ----
  ssh_username           = var.ssh_username
  ssh_pty                = true
  ssh_clear_authorized_keys = true

  # ---- Long build timeouts for STIG + OSCAP ----
  polling_duration_timeout = "2h"

  azure_tags = merge({
    os           = "rhel9"
    compliance   = "cmmc"
    built_by     = "packer"
    build_source = "github-actions"
  }, var.extra_tags)
}
