name: Build CMMC Image

on:
  workflow_dispatch:
    inputs:
      os:
        type: choice
        options: [rhel9]
        default: rhel9
      image_version:
        type: string
        description: "semver x.y.z (leave blank to auto)"
        required: false

permissions:
  id-token: write     # OIDC to Azure
  contents: read

jobs:
  rhel9:
    if: ${{ inputs.os == 'rhel9' }}
    uses: ./.github/workflows/_reusable-packer-build.yml
    with:
      os: rhel9
      image_definition: rhel9-cmmc
      image_version: ${{ inputs.image_version }}
    secrets: inherit


name: _reusable-packer-build

on:
  workflow_call:
    inputs:
      os:               { type: string, required: true }
      image_definition: { type: string, required: true }
      image_version:    { type: string, required: false }

permissions:
  id-token: write
  contents: read

jobs:
  build:
    runs-on: [self-hosted, linux, ghes-runner]
    env:
      # Azure (App Reg / SPN with Federated Credential for this repo)
      ARM_CLIENT_ID:       ${{ vars.AZURE_CLIENT_ID }}
      ARM_TENANT_ID:       ${{ vars.AZURE_TENANT_ID }}
      ARM_SUBSCRIPTION_ID: ${{ vars.AZURE_SUBSCRIPTION_ID }}

      # Packer picks these up via PKR_VAR_*
      PKR_VAR_subscription_id:        ${{ vars.AZURE_SUBSCRIPTION_ID }}
      PKR_VAR_tenant_id:              ${{ vars.AZURE_TENANT_ID }}
      PKR_VAR_client_id:              ${{ vars.AZURE_CLIENT_ID }}
      PKR_VAR_location:               ${{ vars.AZURE_LOCATION }}
      PKR_VAR_build_resource_group:   ${{ vars.BUILD_RG }}
      PKR_VAR_gallery_resource_group: ${{ vars.GALLERY_RG }}
      PKR_VAR_gallery_name:           ${{ vars.GALLERY_NAME }}
      PKR_VAR_image_definition_name:  ${{ inputs.image_definition }}
      PKR_VAR_vnet_name:              ${{ vars.VNET_NAME }}
      PKR_VAR_vnet_resource_group:    ${{ vars.VNET_RG }}
      PKR_VAR_subnet_name:            ${{ vars.SUBNET_NAME }}

    steps:
      - name: Checkout packer repo
        uses: actions/checkout@v4

      - name: Compute image version
        id: ver
        run: |
          if [[ -n "${{ inputs.image_version }}" ]]; then
            echo "v=${{ inputs.image_version }}" >> "$GITHUB_OUTPUT"
          else
            echo "v=$(date -u +%Y.%m.%d).${GITHUB_RUN_NUMBER}" >> "$GITHUB_OUTPUT"
          fi

      - name: Generate GitHub App token (for cloning ansible repos)
        id: app
        uses: actions/create-github-app-token@v1
        with:
          app-id:      ${{ vars.GH_APP_ID }}
          private-key: ${{ secrets.GH_APP_PRIVATE_KEY }}
          owner:       ${{ github.repository_owner }}
          repositories: >-
            ansible-rhel9-stig,
            ansible-cmmc-common,
            ansible-oscap-scan

      - name: Clone ansible content (on runner)
        env:
          GH_TOKEN: ${{ steps.app.outputs.token }}
        run: |
          set -euo pipefail
          mkdir -p ansible-bundle/playbooks ansible-bundle/roles ansible-bundle/vars
          # Clone STIG role into roles/rhel9_stig (path alignment matters)
          git clone --depth=1 \
            "https://x-access-token:${GH_TOKEN}@github.mycorp.mil/org/ansible-rhel9-stig.git" \
            ansible-bundle/roles/rhel9_stig
          git clone --depth=1 \
            "https://x-access-token:${GH_TOKEN}@github.mycorp.mil/org/ansible-cmmc-common.git" \
            ansible-bundle/roles/cmmc_common
          git clone --depth=1 \
            "https://x-access-token:${GH_TOKEN}@github.mycorp.mil/org/ansible-oscap-scan.git" \
            ansible-bundle/roles/oscap_scan
          # Copy our orchestrating playbooks from this repo
          cp -r ansible/playbooks/* ansible-bundle/playbooks/
          cp -r ansible/vars/* ansible-bundle/vars/ 2>/dev/null || true
          [[ -f ansible/requirements.yml ]] && cp ansible/requirements.yml ansible-bundle/
          # Strip any leftover .git (token leak prevention)
          find ansible-bundle -name '.git' -type d -prune -exec rm -rf {} +
          tar -czf /tmp/ansible-bundle.tar.gz -C ansible-bundle .

      - name: Azure login (OIDC to GovCloud)
        uses: azure/login@v2
        with:
          client-id:       ${{ vars.AZURE_CLIENT_ID }}
          tenant-id:       ${{ vars.AZURE_TENANT_ID }}
          subscription-id: ${{ vars.AZURE_SUBSCRIPTION_ID }}
          environment:     AzureUSGovernment
          audience:        api://AzureADTokenExchange

      - name: Packer init + validate
        working-directory: packer/builds/${{ inputs.os }}
        env:
          PKR_VAR_image_version:      ${{ steps.ver.outputs.v }}
          PKR_VAR_ansible_bundle_path: /tmp/ansible-bundle.tar.gz
          PKR_VAR_jfrog_repo_file_path: ${{ github.workspace }}/files/jfrog-rhel9.repo
        run: |
          packer init -upgrade ../../
          packer validate -var-file=variables.pkr.hcl ../../

      - name: Packer build
        working-directory: packer/builds/${{ inputs.os }}
        env:
          PKR_VAR_image_version:       ${{ steps.ver.outputs.v }}
          PKR_VAR_ansible_bundle_path: /tmp/ansible-bundle.tar.gz
          PKR_VAR_jfrog_repo_file_path: ${{ github.workspace }}/files/jfrog-rhel9.repo
          PACKER_LOG: 1
          PACKER_LOG_PATH: ${{ github.workspace }}/packer.log
        run: packer build -color=false ../../

      - name: Upload OSCAP + packer logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: oscap-${{ inputs.os }}-${{ steps.ver.outputs.v }}
          path: |
            packer/builds/${{ inputs.os }}/oscap-results/**
            packer.log
          retention-days: 90

      - name: Scrub bundle
        if: always()
        run: rm -f /tmp/ansible-bundle.tar.gz && rm -rf ansible-bundle
