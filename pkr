build {
  name = "rhel9-cmmc"
  sources = ["source.azure-arm.rhel9"]

  # 1) Drop JFrog repo file before we try any yum operations
  provisioner "file" {
    source      = var.jfrog_repo_file_path
    destination = "/tmp/jfrog-rhel9.repo"
  }

  # 2) Bootstrap: disable RH subscription repos, install JFrog repo,
  #    install python3 + ansible-core from the mirror
  provisioner "shell" {
    execute_command = "sudo -E bash '{{ .Path }}'"
    scripts = ["scripts/00-bootstrap-ansible.sh"]
  }

  # 3) Upload the ansible bundle (pre-cloned on the runner via GH App token)
  provisioner "file" {
    source      = var.ansible_bundle_path   # /tmp/ansible-bundle.tar.gz on runner
    destination = "/tmp/ansible-bundle.tar.gz"
  }

  # 4) Run patching + FIPS enable playbook (no reboot inside ansible)
  provisioner "shell" {
    execute_command = "sudo -E bash '{{ .Path }}'"
    environment_vars = ["PLAYBOOK=01-prep-and-fips.yml"]
    scripts = ["scripts/10-run-ansible.sh"]
  }

  # 5) Reboot — Packer handles disconnect, waits for SSH
  provisioner "shell" {
    inline              = ["sudo /sbin/shutdown -r +0 'packer fips reboot'"]
    expect_disconnect   = true
    skip_clean          = true
  }

  # 6) Verify FIPS is actually on after reboot
  provisioner "shell" {
    pause_before    = "45s"
    execute_command = "sudo -E bash '{{ .Path }}'"
    scripts         = ["scripts/20-reboot-wait.sh"]
  }

  # 7) STIG hardening
  provisioner "shell" {
    execute_command  = "sudo -E bash '{{ .Path }}'"
    environment_vars = ["PLAYBOOK=02-stig-harden.yml"]
    scripts          = ["scripts/10-run-ansible.sh"]
  }

  # 8) OSCAP scan
  provisioner "shell" {
    execute_command  = "sudo -E bash '{{ .Path }}'"
    environment_vars = ["PLAYBOOK=03-oscap-scan.yml"]
    scripts          = ["scripts/10-run-ansible.sh"]
  }

  # 9) Pull OSCAP artifacts back to the runner for CI upload
  provisioner "file" {
    direction   = "download"
    source      = "/var/tmp/oscap/"
    destination = "./oscap-results/"
  }

  # 10) Deprovision (waagent) + remove traces of ansible bundle, tokens, ssh keys
  provisioner "shell" {
    execute_command = "sudo -E bash '{{ .Path }}'"
    scripts         = ["scripts/99-deprovision.sh"]
    skip_clean      = true
  }
}
