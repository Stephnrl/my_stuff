#!/usr/bin/env bash
#
# scripts/20-reboot-wait.sh  (a.k.a. 02-reboot-wait.sh)
#
# Runs AFTER the post-FIPS reboot. Verifies:
#   1. SSH came back (implicit — if we're running, it did)
#   2. System finished booting (not still in "starting" state)
#   3. FIPS is actually enabled in the kernel
#   4. Crypto policy reports FIPS
#   5. /boot is mounted (FIPS integrity check depends on it)
#   6. waagent is new enough for FIPS 140-3
#   7. waagent.service is active and not stuck in a restart loop
#   8. waagent successfully fetched a goal state post-FIPS
#      (this is the exact failure mode the historical bug produced)
#   9. No known-bad error signatures in waagent.log
#
# Exits non-zero on any failure so Packer aborts the build BEFORE
# we bake a broken image into the gallery.

set -euo pipefail

LOG=/var/log/packer-fips-verify.log
exec > >(tee -a "$LOG") 2>&1

echo "=========================================="
echo "Post-FIPS-reboot verification"
echo "Started: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "=========================================="

fail() {
  echo ""
  echo "FAIL: $*"
  echo ""
  echo "--- Last 80 lines of waagent.log ---"
  tail -80 /var/log/waagent.log 2>/dev/null || echo "(no waagent.log)"
  echo "--- systemctl status waagent ---"
  systemctl status waagent --no-pager -l 2>/dev/null || true
  echo "--- journalctl -u waagent (last 50) ---"
  journalctl -u waagent --no-pager -n 50 2>/dev/null || true
  exit 1
}

# ---------------------------------------------------------------------------
# 1. Wait for systemd to finish booting.
#    Without this, subsequent checks race against services still starting.
# ---------------------------------------------------------------------------
echo ""
echo "[1/9] Waiting for system boot to settle..."
for i in $(seq 1 30); do
  state=$(systemctl is-system-running 2>/dev/null || true)
  case "$state" in
    running|degraded)
      echo "      system state: $state"
      # 'degraded' is acceptable — some STIG lockdowns intentionally
      # leave services masked. We just need boot to have finished.
      break
      ;;
    starting|initializing)
      sleep 5
      ;;
    *)
      # Unknown state; give it a beat then re-check
      sleep 5
      ;;
  esac
  if [[ $i -eq 30 ]]; then
    fail "system did not finish booting after 150s (last state: $state)"
  fi
done

# ---------------------------------------------------------------------------
# 2. Kernel FIPS flag
# ---------------------------------------------------------------------------
echo ""
echo "[2/9] Checking /proc/sys/crypto/fips_enabled..."
fips_flag=$(cat /proc/sys/crypto/fips_enabled 2>/dev/null || echo "missing")
if [[ "$fips_flag" != "1" ]]; then
  fail "kernel fips_enabled is '$fips_flag', expected '1'"
fi
echo "      OK: kernel fips_enabled=1"

# ---------------------------------------------------------------------------
# 3. fips-mode-setup agrees
# ---------------------------------------------------------------------------
echo ""
echo "[3/9] Checking fips-mode-setup --check..."
if ! fips-mode-setup --check | grep -q "FIPS mode is enabled."; then
  fail "fips-mode-setup disagrees with kernel flag"
fi
echo "      OK: fips-mode-setup reports enabled"

# ---------------------------------------------------------------------------
# 4. System-wide crypto policy is FIPS
# ---------------------------------------------------------------------------
echo ""
echo "[4/9] Checking system crypto policy..."
policy=$(update-crypto-policies --show 2>/dev/null || echo "unknown")
if [[ "$policy" != "FIPS" ]]; then
  fail "crypto policy is '$policy', expected 'FIPS'"
fi
echo "      OK: crypto policy = FIPS"

# ---------------------------------------------------------------------------
# 5. /boot is mounted (FIPS integrity check depends on it)
# ---------------------------------------------------------------------------
echo ""
echo "[5/9] Checking /boot is mounted..."
if ! mountpoint -q /boot; then
  # Not necessarily fatal on every marketplace image, but worth logging loudly
  echo "      WARN: /boot is not a separate mountpoint"
  echo "            STIG will flag this; document or re-partition at build time"
else
  echo "      OK: /boot is mounted"
fi

# ---------------------------------------------------------------------------
# 6. waagent version is >= 2.14.0.1 (minimum for FIPS 140-3 goal state)
# ---------------------------------------------------------------------------
echo ""
echo "[6/9] Checking waagent version..."
if ! command -v waagent >/dev/null 2>&1; then
  fail "waagent binary not found"
fi

wa_raw=$(waagent --version 2>/dev/null | head -1)
echo "      waagent: $wa_raw"

# Extract just the version number: "WALinuxAgent-2.14.0.1 running on ..." -> "2.14.0.1"
wa_ver=$(echo "$wa_raw" | sed -nE 's/^WALinuxAgent-([0-9]+(\.[0-9]+)+).*/\1/p')
if [[ -z "$wa_ver" ]]; then
  fail "could not parse waagent version from: $wa_raw"
fi

# Version comparison via sort -V
min_ver="2.14.0.1"
lowest=$(printf '%s\n%s\n' "$wa_ver" "$min_ver" | sort -V | head -1)
if [[ "$lowest" != "$min_ver" ]]; then
  fail "waagent $wa_ver is older than required $min_ver for FIPS 140-3"
fi
echo "      OK: waagent $wa_ver >= $min_ver"

# ---------------------------------------------------------------------------
# 7. waagent.service is active
# ---------------------------------------------------------------------------
echo ""
echo "[7/9] Checking waagent.service status..."
if ! systemctl is-active --quiet waagent; then
  fail "waagent.service is not active"
fi

# Detect the "internal loop, never Ready" failure mode explicitly:
# if the service has restarted a lot in a short window, that's the symptom.
restart_count=$(systemctl show waagent -p NRestarts --value 2>/dev/null || echo "0")
if [[ "$restart_count" -gt 5 ]]; then
  fail "waagent.service has restarted $restart_count times — likely stuck in FIPS loop"
fi
echo "      OK: waagent.service active (restarts: $restart_count)"

# ---------------------------------------------------------------------------
# 8. waagent successfully fetched a goal state post-FIPS.
#    This is THE canary for the historical bug. If waagent can't decrypt
#    Certificates.p7m under FIPS, it never gets past goal-state fetch.
# ---------------------------------------------------------------------------
echo ""
echo "[8/9] Waiting for waagent to fetch goal state post-FIPS..."

# /var/log/waagent.log may have been truncated on reboot; be patient.
deadline=$(( $(date +%s) + 300 ))   # up to 5 minutes
goal_state_ok=0

while [[ $(date +%s) -lt $deadline ]]; do
  if [[ -f /var/log/waagent.log ]]; then
    # Positive signal: agent reports fetching an incarnation or goal state
    if grep -qE "Fetched a new incarnation|Fetched goal state|Goal state .* fetched" \
         /var/log/waagent.log; then
      goal_state_ok=1
      break
    fi
    # Negative signal: the specific bug pattern. Fail fast.
    if grep -qE "Failed to decrypt .*Certificates\.p7m|FIPS mode not supported|Error converting PFX to PEM" \
         /var/log/waagent.log; then
      fail "waagent hit the known FIPS goal-state decryption bug"
    fi
  fi
  sleep 10
done

if [[ $goal_state_ok -ne 1 ]]; then
  fail "waagent did not fetch a goal state within 5 minutes post-FIPS"
fi
echo "      OK: waagent fetched goal state successfully"

# ---------------------------------------------------------------------------
# 9. Final scan for any ERROR-level entries in waagent.log since reboot
# ---------------------------------------------------------------------------
echo ""
echo "[9/9] Scanning waagent.log for ERROR entries..."
err_count=$(grep -cE '^\S+ ERROR ' /var/log/waagent.log 2>/dev/null || echo "0")
if [[ "$err_count" -gt 0 ]]; then
  echo "      WARN: $err_count ERROR lines in waagent.log (inspect manually):"
  grep -E '^\S+ ERROR ' /var/log/waagent.log | head -10
  # Not a hard fail — some transient errors are normal during boot.
  # Escalate to fail if your policy requires it.
else
  echo "      OK: no ERROR entries"
fi

echo ""
echo "=========================================="
echo "Post-FIPS verification PASSED"
echo "Finished: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "=========================================="

# Copy this log to the OSCAP bundle dir so it rides out with results
mkdir -p /var/tmp/oscap
cp "$LOG" /var/tmp/oscap/packer-fips-verify.log 2>/dev/null || true

exit 0
