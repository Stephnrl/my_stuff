- hosts: localhost
  become: true
  gather_facts: true
  vars:
    waagent_min_version: "2.14.0.1"
  tasks:
    - name: Patch system
      ansible.builtin.dnf:
        name: "*"
        state: latest
        update_cache: true

    # Azure-tuned RHEL marketplace images ship a waagent RPM from Red Hat
    # that's typically older than what we need for FIPS 140-3.
    # Upgrade it explicitly from the JFrog-mirrored Microsoft repo.
    - name: Ensure WALinuxAgent is new enough for FIPS 140-3
      ansible.builtin.dnf:
        name: WALinuxAgent
        state: latest

    - name: Capture waagent version
      ansible.builtin.command: waagent --version
      register: waagent_ver
      changed_when: false

    - name: Fail if waagent is too old for FIPS 140-3
      ansible.builtin.assert:
        that:
          - waagent_ver.stdout is search('WALinuxAgent-(2\.(1[4-9]|[2-9][0-9])|[3-9])')
        fail_msg: >-
          waagent is older than 2.14.0.1 ({{ waagent_ver.stdout }}).
          FIPS + this waagent = broken goal state. Update the JFrog mirror.

    - name: Install crypto + FIPS prereqs
      ansible.builtin.dnf:
        name:
          - crypto-policies
          - crypto-policies-scripts
        state: present

    - name: Ensure waagent AutoUpdate is enabled
      ansible.builtin.lineinfile:
        path: /etc/waagent.conf
        regexp: '^AutoUpdate\.Enabled='
        line: 'AutoUpdate.Enabled=y'

    # Do NOT set OS.EnableFIPS=y in waagent.conf. That legacy flag forces
    # waagent to emit OPENSSL_FIPS=1 to child openssl calls, which under
    # FIPS 140-3 support is the wrong path. Leave it default (n).
    - name: Ensure legacy OS.EnableFIPS is NOT set
      ansible.builtin.lineinfile:
        path: /etc/waagent.conf
        regexp: '^OS\.EnableFIPS='
        line: 'OS.EnableFIPS=n'

    - name: Enable FIPS mode (reboot handled by Packer)
      ansible.builtin.command: fips-mode-setup --enable
      register: fips_out
      changed_when: "'FIPS mode will be enabled' in fips_out.stdout"
