repo_profiles:
  security:
    match_dirs:
      - guardduty
      - aws_config
      - iam_access_analyzer
      - cw_oam_sink
      - cw_oam_link

  eks:
    match_resources:
      - aws_eks_cluster
      - aws_eks_node_group
      - aws_eks_addon

account_scopes:
  security_account:
    match_dirs:
      - guardduty
      - aws_config
      - iam_access_analyzer
      - cw_oam_sink
      - securityhub
      - detective
      - macie

  member_account:
    match_dirs:
      - cw_oam_link
      - member
      - account-baseline

  eks_account:
    match_resources:
      - aws_eks_cluster
      - aws_eks_node_group
      - aws_eks_addon

relationships:
  - name: cloudwatch_oam
    from_resource_type: aws_oam_link
    to_resource_type: aws_oam_sink
    label: shares telemetry

  - name: eks_nodes_to_cluster
    from_resource_type: aws_eks_node_group
    to_resource_type: aws_eks_cluster
    label: joins

  - name: eks_addons_to_cluster
    from_resource_type: aws_eks_addon
    to_resource_type: aws_eks_cluster
    label: installed on

  - name: config_aggregator
    from_resource_type: aws_config_configuration_recorder
    to_resource_type: aws_config_configuration_aggregator
    label: reports to
