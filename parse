from __future__ import annotations

import argparse
import json
from pathlib import Path

from tf_parser import parse_repo
from diagrams_writer import write_overview_diagram, write_service_diagram


def main() -> None:
    parser = argparse.ArgumentParser(description="Generate architecture diagrams from Terraform.")
    parser.add_argument("--repo", required=True, help="Path to Terraform repository")
    parser.add_argument("--name", required=True, help="Diagram/repo name")
    parser.add_argument("--out", required=True, help="Output directory")
    parser.add_argument(
        "--mappings",
        default="tools/diagrammer/mappings.yaml",
        help="Path to mappings.yaml",
    )
    parser.add_argument(
        "--write-model",
        action="store_true",
        help="Write parsed diagram model JSON",
    )

    args = parser.parse_args()

    repo = Path(args.repo).resolve()
    out = Path(args.out).resolve()
    mappings = Path(args.mappings).resolve()

    model = parse_repo(repo)

    out.mkdir(parents=True, exist_ok=True)

    if args.write_model:
        model_path = out / "diagram-model.json"
        with model_path.open("w", encoding="utf-8") as f:
            json.dump(model, f, indent=2, default=str)

    write_overview_diagram(
        model=model,
        mappings_path=mappings,
        out_dir=out,
        diagram_name=f"{args.name} Module Overview",
    )

    write_service_diagram(
        model=model,
        mappings_path=mappings,
        out_dir=out,
        diagram_name=f"{args.name} Service Overview",
    )

    if model["errors"]:
        print("Some Terraform files could not be parsed:")
        for error in model["errors"]:
            print(f"- {error['file']}: {error['error']}")

    print(f"Wrote diagrams to {out}")


if __name__ == "__main__":
    main()
