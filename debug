#!/usr/bin/env python3
"""
tfstate-visualizer: Parse a Terraform state file and generate an interactive HTML infrastructure diagram.

Usage:
    python tfstate_visualizer.py <path-to-terraform.tfstate> [-o output.html]

The generated HTML is fully standalone (zero external dependencies at runtime)
and works perfectly on GitHub Pages or any static hosting.
"""

