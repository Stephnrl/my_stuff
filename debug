def _guess_category(resource_type: str) -> str:
    """Best-guess which diagrams.aws category a resource belongs in."""
    rt = resource_type.lower()
    if any(kw in rt for kw in ("vpc", "subnet", "gateway", "route", "acl", "eip",
                                "lb", "alb", "nlb", "elb", "peering", "transit",
                                "vpn", "endpoint", "network", "flow_log",
                                "route53", "cloudfront", "direct_connect", "prefix_list")):
        return "network"
    if any(kw in rt for kw in ("ec2", "instance", "launch", "autoscaling", "eks",
                                "ecs", "ecr", "lambda", "fargate", "batch")):
        return "compute"
    if any(kw in rt for kw in ("s3", "ebs", "efs", "fsx", "backup")):
        return "storage"
    if any(kw in rt for kw in ("rds", "db_", "dynamodb", "elasticache", "redshift",
                                "neptune", "docdb", "aurora")):
        return "database"
    if any(kw in rt for kw in ("iam", "kms", "acm", "secret", "waf", "guard",
                                "security_group", "inspector", "macie", "shield")):
        return "security"
    if any(kw in rt for kw in ("cloudwatch", "cloudtrail", "ssm", "config",
                                "cloudformation", "sns", "sqs")):
        return "management"
    return "general"


