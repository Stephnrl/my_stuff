    "Other":      "#94a3b8",
}


def parse_tfstate(path: str) -> dict:
    """Read and validate a Terraform state file."""
    with open(path) as f:
        state = json.load(f)
    if "resources" not in state:
        raise ValueError("Invalid tfstate: missing 'resources' key")
    return state


def extract_graph(state: dict) -> tuple[list[dict], list[dict]]:
    """
    Extract nodes and edges from the state file.
    Returns (nodes, edges).
    """
    nodes = []
    edges = []
    seen_edges = set()

    for res in state.get("resources", []):
        if res.get("mode") == "data":
            continue  # skip data sources

        res_type = res["type"]
        res_name = res["name"]
        full_name = f"{res_type}.{res_name}"
        category, color, icon = CATEGORY_MAP.get(res_type, DEFAULT_CATEGORY)

        # Pull useful attributes from the first instance
        attrs = {}
        deps = []
        if res.get("instances"):
            inst = res["instances"][0]
            attrs = inst.get("attributes", {})
            deps = inst.get("dependencies", [])

        # Build display label
        display_name = (attrs.get("tags", {}) or {}).get("Name", res_name)
        detail_lines = _build_details(res_type, attrs)

        nodes.append({
            "id":       full_name,
            "label":    display_name,
            "type":     res_type,
            "category": category,
            "color":    color,
            "icon":     icon,
            "details":  detail_lines,
            "attrs":    _safe_attrs(attrs),
        })

        for dep in deps:
            edge_key = (dep, full_name)
            if edge_key not in seen_edges:
                seen_edges.add(edge_key)
                edges.append({"from": dep, "to": full_name})

    return nodes, edges


def _build_details(res_type: str, attrs: dict) -> list[str]:
    """Build human-readable detail lines for a resource."""
    lines = []
    interesting_keys = {
        "cidr_block", "availability_zone", "engine", "engine_version",
        "instance_class", "allocated_storage", "cpu", "memory",
        "desired_count", "launch_type", "port", "protocol",
        "domain_name", "dns_name", "bucket", "name", "public_ip",
        "load_balancer_type", "retention_in_days", "multi_az",
        "storage_encrypted", "target_type",
    }
    for key in interesting_keys:
        if key in attrs and attrs[key] not in (None, "", [], {}):
            val = attrs[key]
            if isinstance(val, bool):
                val = "Yes" if val else "No"
            lines.append(f"{_humanize(key)}: {val}")
    return sorted(lines)


def _humanize(key: str) -> str:
    return key.replace("_", " ").title()


def _safe_attrs(attrs: dict) -> dict:
    """Return a JSON-safe subset of attributes (no huge nested blobs)."""
    safe = {}
    for k, v in attrs.items():
        if k in ("tags", "id"):
            safe[k] = v
        elif isinstance(v, (str, int, float, bool)):
            safe[k] = v
        elif isinstance(v, list) and len(v) < 5:
            safe[k] = v
    return safe


def _uid(s: str) -> str:
    return hashlib.md5(s.encode()).hexdigest()[:8]


def build_html(nodes: list[dict], edges: list[dict], state: dict, tfstate_path: str) -> str:
    """Generate the full standalone HTML page."""
    meta = {
        "terraform_version": state.get("terraform_version", "unknown"),
        "serial":            state.get("serial", "?"),
        "resource_count":    len(nodes),
        "edge_count":        len(edges),
        "file":              Path(tfstate_path).name,
    }

    # Group nodes by category for stats
    cat_counts = defaultdict(int)
    for n in nodes:
        cat_counts[n["category"]] += 1

    nodes_json = json.dumps(nodes, indent=2)
    edges_json = json.dumps(edges, indent=2)
    meta_json  = json.dumps(meta, indent=2)
    cat_colors_json = json.dumps(CATEGORY_COLORS)
    cat_counts_json = json.dumps(dict(cat_counts))

    return HTML_TEMPLATE.replace("__NODES__", nodes_json) \
                        .replace("__EDGES__", edges_json) \
                        .replace("__META__",  meta_json) \
                        .replace("__CAT_COLORS__", cat_colors_json) \
                        .replace("__CAT_COUNTS__", cat_counts_json)


