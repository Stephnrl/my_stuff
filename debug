Step 2 — the re-register function
powershell
function Reset-GhRunner {
  param(
    [Parameter(Mandatory)][string]$Dir,
    [Parameter(Mandatory)][string]$Name,
    [Parameter(Mandatory)][string]$Labels,     # comma-separated, custom only
    [string]$Group = 'Default',
    [Parameter(Mandatory)][string]$Url,
    [Parameter(Mandatory)][string]$RegToken,
    [Parameter(Mandatory)][string]$RmToken,
    [Parameter(Mandatory)][pscredential]$Cred
  )

  Write-Host "`n=== $Name ($Dir) ===" -ForegroundColor Cyan
  Push-Location $Dir

  try {
    $svc = Get-CimInstance Win32_Service -Filter "Name LIKE 'actions.runner%'" |
             Where-Object { $_.PathName -like "*$Dir*" }
    if ($svc) {
      Write-Host "Stopping $($svc.Name)..."
      Stop-Service $svc.Name -Force -ErrorAction SilentlyContinue
      (Get-Service $svc.Name).WaitForStatus('Stopped','00:00:60')
    }

    if (Get-Process Runner.Worker -ErrorAction SilentlyContinue |
          Where-Object { $_.Path -like "$Dir*" }) {
      Write-Warning "Live worker in $Dir — job may be running. Aborting."
      return
    }

    Write-Host "Removing registration..."
    & .\config.cmd remove --token $RmToken
    if ($LASTEXITCODE -ne 0) {
      Write-Warning "config remove exited $LASTEXITCODE — clearing local state."
      Remove-Item .runner,.credentials,.credentials_rsaparams -Force -ErrorAction SilentlyContinue
    }

    Write-Host "Registering..."
    & .\config.cmd `
        --unattended `
        --replace `
        --url  $Url `
        --token $RegToken `
        --name $Name `
        --labels $Labels `
        --runnergroup $Group `
        --work '_work' `
        --runasservice `
        --windowslogonaccount $Cred.UserName `
        --windowslogonpassword $Cred.GetNetworkCredential().Password

    if ($LASTEXITCODE -ne 0) { throw "config.cmd failed with exit code $LASTEXITCODE" }

    $newSvc = Get-CimInstance Win32_Service -Filter "Name LIKE 'actions.runner%'" |
                Where-Object { $_.PathName -like "*$Dir*" }
    Start-Service $newSvc.Name
    (Get-Service $newSvc.Name).WaitForStatus('Running','00:00:60')
    Write-Host "$($newSvc.Name): $((Get-Service $newSvc.Name).Status)" -ForegroundColor Green
  }
  finally { Pop-Location }
}
