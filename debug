# ──────────────────────────────────────────────────────────────
# TF PARSER
# ──────────────────────────────────────────────────────────────

@dataclass
class TFResource:
    resource_type: str      # e.g. "aws_vpc"
    name: str               # e.g. "this"
    source_file: str        # e.g. "main.tf"

@dataclass
class ModuleDirectory:
    path: str
    name: str
    resources: list[TFResource] = field(default_factory=list)


# Regex to match: resource "aws_thing" "name" {
RESOURCE_RE = re.compile(
    r'resource\s+"([^"]+)"\s+"([^"]+)"', re.MULTILINE
)


def parse_tf_file(filepath: str) -> list[TFResource]:
    """Extract all resource blocks from a .tf file."""
    resources = []
    with open(filepath, "r") as f:
        content = f.read()
    for match in RESOURCE_RE.finditer(content):
        resources.append(TFResource(
            resource_type=match.group(1),
            name=match.group(2),
            source_file=os.path.basename(filepath),
        ))
    return resources


def scan_module(module_path: str) -> list[ModuleDirectory]:
    """Walk top-level dirs in a TF module and parse all .tf files."""
    module_path = os.path.abspath(module_path)
    directories = []

    # Scan root-level .tf files
    root_dir = ModuleDirectory(path=module_path, name="(root)")
    for tf_file in sorted(Path(module_path).glob("*.tf")):
        root_dir.resources.extend(parse_tf_file(str(tf_file)))
    if root_dir.resources:
        directories.append(root_dir)

    for entry in sorted(os.listdir(module_path)):
        full_path = os.path.join(module_path, entry)
        if not os.path.isdir(full_path):
            continue
        # Skip hidden dirs and common non-module dirs
        if entry.startswith(".") or entry in {"modules", ".terraform", ".git"}:
            continue

        mod_dir = ModuleDirectory(path=full_path, name=entry)
        for tf_file in sorted(Path(full_path).rglob("*.tf")):
            mod_dir.resources.extend(parse_tf_file(str(tf_file)))
        if mod_dir.resources:
            directories.append(mod_dir)

    return directories


