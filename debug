Get-CimInstance Win32_Process -Filter "Name='Runner.Worker.exe'" |
  Select-Object ProcessId, ParentProcessId, CreationDate, ExecutablePath


Get-ChildItem D:\enterprise-cloud-runners -Directory | ForEach-Object {
  $cfg = Join-Path $_.FullName '.runner'
  if (Test-Path $cfg) {
    $j = Get-Content $cfg -Raw | ConvertFrom-Json
    [pscustomobject]@{
      Dir       = $_.Name
      AgentName = $j.agentName
      Server    = $j.gitHubUrl
      Worker    = (Test-Path (Join-Path $_.FullName '_work'))
    }
  }
}



Get-ChildItem D:\enterprise-cloud-runners\*\_diag\Worker_*.log |
  Sort-Object LastWriteTime -Descending |
  Select-Object -First 5 LastWriteTime, FullName

Get-ChildItem D:\enterprise-cloud-runners\*\_diag\Worker_*.log |
  Sort-Object LastWriteTime -Descending | Select-Object -First 1 |
  Get-Content -Tail 80


Get-CimInstance Win32_Service -Filter "Name LIKE 'actions.runner%'" |
  Select-Object Name, State, ProcessId, PathName | Format-Table -Wrap
