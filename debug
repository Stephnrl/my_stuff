Get-CimInstance Win32_Service -Filter "Name LIKE 'actions.runner%'" |
  Select-Object Name, State, StartMode, ProcessId, StartName | Format-Table -AutoSize

Get-Service actions.runner.* | Select-Object Name, Status
Get-Process Runner.Listener -ErrorAction SilentlyContinue |
  Select-Object Id, StartTime, @{n='Dir';e={Split-Path $_.Path -Parent}}


Get-CimInstance Win32_Process -Filter "Name='Runner.Worker.exe'" |
  Select-Object ProcessId, CreationDate, ExecutablePath


'OLDDOMAIN\svc-gh-runner','NEWDOMAIN\svc-gh-runner' | ForEach-Object {
  try {
    $sid = (New-Object System.Security.Principal.NTAccount($_)).Translate(
             [System.Security.Principal.SecurityIdentifier]).Value
    [pscustomobject]@{ Account=$_; Resolves=$true; SID=$sid }
  } catch {
    [pscustomobject]@{ Account=$_; Resolves=$false; SID=$null }
  }
}


Get-ChildItem D:\enterprise-cloud-runners\4\_diag\Worker_*.log |
  Sort-Object LastWriteTime -Desc | Select-Object -First 1 |
  ForEach-Object {
    "=== $($_.FullName)  (last write: $($_.LastWriteTime)) ==="
    Get-Content $_ -TotalCount 40 
    "--- tail ---"
    Get-Content $_ -Tail 40
  }


Get-ChildItem D:\enterprise-cloud-runners\*\_diag\Runner_*.log |
  Group-Object { $_.FullName.Split('\')[2] } | ForEach-Object {
    $n = $_.Group | Sort-Object LastWriteTime -Desc | Select-Object -First 1
    [pscustomobject]@{
      Runner = $_.Name
      Last   = $n.LastWriteTime
      State  = if ((Get-Content $n.FullName -Tail 20) -match 'renew job') {'BUSY'}
               elseif ((Get-Content $n.FullName -Tail 20) -match 'Listening for Jobs') {'IDLE'}
               else {'UNKNOWN'}
    }
  } | Format-Table -AutoSize


Get-CimInstance Win32_Process -Filter "Name='Runner.Worker.exe'" |
  Where-Object ExecutablePath -like 'D:\enterprise-cloud-runners\4\*' |
  ForEach-Object { Stop-Process -Id $_.ProcessId -Force }

Restart-Service "actions.runner.*4*"


Get-CimInstance Win32_Process -Filter "Name='Runner.Worker.exe'" |
  Select-Object ProcessId, CreationDate, ExecutablePath | Format-Table -AutoSize



Get-Service actions.runner.* | ForEach-Object {
  Write-Host "Restarting $($_.Name)..."
  Restart-Service $_.Name -Force
  $_.WaitForStatus('Running','00:00:30')
  "{0} -> {1}" -f $_.Name, (Get-Service $_.Name).Status
}





Get-ChildItem D:\enterprise-cloud-runners\*\_diag\Runner_*.log |
  Select-String -Pattern 'BrokerServer|995|TaskCanceledException' |
  ForEach-Object { $_.Line.Substring(0, [Math]::Min(30, $_.Line.Length)) } |
  Select-Object -Last 40


'api.github.com','broker.actions.githubusercontent.com','pipelines.actions.githubusercontent.com' |
  ForEach-Object { Test-NetConnection $_ -Port 443 | Select-Object ComputerName, TcpTestSucceeded }
