Get-CimInstance Win32_Service -Filter "Name LIKE 'actions.runner%'" |
  Select-Object Name, StartName, State, StartMode


'OLDDOMAIN\svc-gh-runner','NEWDOMAIN\svc-gh-runner' | ForEach-Object {
  try {
    $sid = (New-Object System.Security.Principal.NTAccount($_)).Translate(
             [System.Security.Principal.SecurityIdentifier]).Value
    [pscustomobject]@{ Account=$_; Resolves=$true; SID=$sid }
  } catch {
    [pscustomobject]@{ Account=$_; Resolves=$false; SID=$null }
  }
}
