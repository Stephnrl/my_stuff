# CLI
# ═══════════════════════════════════════════════════════════════════════════════
def main():
    parser = argparse.ArgumentParser(
        description="Generate an interactive HTML infrastructure diagram from a Terraform state file."
    )
    parser.add_argument("tfstate", help="Path to the terraform.tfstate file")
    parser.add_argument("-o", "--output", default="infra-map.html",
                        help="Output HTML file (default: infra-map.html)")
    args = parser.parse_args()

    print(f"📂 Reading state file: {args.tfstate}")
    state = parse_tfstate(args.tfstate)

    print(f"🔍 Extracting resources and dependencies…")
    nodes, edges = extract_graph(state)
    print(f"   Found {len(nodes)} resources and {len(edges)} dependency edges")

    print(f"🎨 Generating HTML diagram…")
    html = build_html(nodes, edges, state, args.tfstate)

    out_path = Path(args.output)
    out_path.write_text(html)
    print(f"✅ Written to {out_path.resolve()}")
    print(f"   Open in browser or push to GitHub Pages!")


if __name__ == "__main__":
    main()
