name: Deploy Internal GHES Pages

on:
  # Runs on pushes targeting the default branch
  push:
    branches: ["main"]
  # Allows you to run this workflow manually from the Actions tab
  workflow_dispatch:

# Sets permissions of the GITHUB_TOKEN to allow deployment to internal GitHub Pages
permissions:
  contents: read
  pages: write
  id-token: write

# Allow only one concurrent deployment to prevent race conditions
concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    
    # Executing on internal infrastructure
    runs-on: self-hosted
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Setup Pages
        uses: actions/configure-pages@v3

      - name: Upload artifact
        # Using v3 for broader GHES 3.17 compatibility 
        uses: actions/upload-pages-artifact@v3
        with:
          # Upload the entire 'public' directory created in the previous step
          path: './public'

      - name: Deploy to GitHub Pages
        id: deployment
        # Using v3 for broader GHES 3.17 compatibility
        uses: actions/deploy-pages@v3
