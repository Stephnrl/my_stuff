def _suggest_class(resource_type: str, category: str) -> str:
    """Pick the best icon class for an unmapped resource type."""
    rt = resource_type.lower()
    for keyword, cls in _KEYWORD_TO_CLASS.items():
        if keyword in rt:
            return cls
    # Fallback: first candidate for the category
    candidates = _CATEGORY_HINTS.get(category, ["General"])
    return candidates[0]


def audit_module(module_path: str) -> None:
    """
    Scan a Terraform module and report:
      - Which resource types are fully mapped (with icon)
      - Which resource types are UNMAPPED (will get a generic icon)
      - A suggested RESOURCE_REGISTRY entry for each unmapped type
    """
    directories = scan_module(module_path)
    if not directories:
        print(f"  No terraform directories with resources found in {module_path}")
        sys.exit(1)

    # Collect all unique resource types across the module
    all_types: dict[str, list[str]] = {}  # resource_type -> [dir_names]
    for d in directories:
        for r in d.resources:
            all_types.setdefault(r.resource_type, []).append(d.name)

    mapped = {}
    unmapped = {}
    for rtype, dirs in sorted(all_types.items()):
        if rtype in RESOURCE_REGISTRY:
            mapped[rtype] = dirs
        else:
            unmapped[rtype] = dirs

    total = len(all_types)
    n_mapped = len(mapped)
    n_unmapped = len(unmapped)
    coverage = (n_mapped / total * 100) if total else 0

    # ── Header ──
    print(f"\n{'='*68}")
    print(f"  AUDIT: {os.path.abspath(module_path)}")
    print(f"{'='*68}")
    print(f"\n  Resource types found:   {total}")
    print(f"  Mapped (have icon):     {n_mapped}")
    print(f"  Unmapped (generic icon): {n_unmapped}")
    print(f"  Coverage:               {coverage:.0f}%\n")

    # ── Mapped resources ──
    if mapped:
        print(f"  {'MAPPED RESOURCES':^64}")
        print(f"  {'-'*64}")
        for rtype, dirs in sorted(mapped.items()):
            cat, cls = RESOURCE_REGISTRY[rtype]
            dir_list = ", ".join(sorted(set(dirs)))
            print(f"  ✓ {rtype:45s} → {cat}.{cls}")
            print(f"    found in: {dir_list}")
        print()

    # ── Unmapped resources ──
    if unmapped:
        print(f"  {'UNMAPPED RESOURCES (need entries)':^64}")
        print(f"  {'-'*64}")
        for rtype, dirs in sorted(unmapped.items()):
            dir_list = ", ".join(sorted(set(dirs)))
            category = _guess_category(rtype)
            candidates = _CATEGORY_HINTS.get(category, ["General"])
            print(f"  ✗ {rtype:45s}   [{category}]")
            print(f"    found in: {dir_list}")
            print(f"    suggested icons: {', '.join(candidates[:5])}")
        print()

        # ── Copy-paste snippet ──
        print(f"  {'COPY-PASTE SNIPPET':^64}")
        print(f"  {'-'*64}")
        print("  Add these to RESOURCE_REGISTRY:\n")
        for rtype in sorted(unmapped.keys()):
            category = _guess_category(rtype)
            suggested_cls = _suggest_class(rtype, category)
            # Pad for alignment
            print(f'    "{rtype}":{" " * max(1, 44 - len(rtype))}("{category}", "{suggested_cls}"),')
        print()
    else:
        print("  All resource types are mapped. You're good to go.\n")

    print(f"{'='*68}\n")


