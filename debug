template:
  spec:
    affinity:
      nodeAffinity:
        requiredDuringSchedulingIgnoredDuringExecution:
          nodeSelectorTerms:
            - matchExpressions:
                - key: agentpool
                  operator: In
                  values:
                    - nplinuxfips
                    - nplinuxfips2
    # Only needed if your FIPS pools have taints. Check with:
    #   kubectl describe node <one-of-the-fips-nodes> | grep Taints
