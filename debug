#Requires -RunAsAdministrator
<#
.SYNOPSIS
    Installs Visual Studio 2022 Build Tools (MSBuild 17.x) on Windows Server 2019.
    Intended for GitHub Actions self-hosted runners.

.DESCRIPTION
    Downloads the VS 2022 Build Tools bootstrapper and runs a silent install
    with the MSBuild and .NET desktop build workloads. Validates the install
    by checking for MSBuild.exe via vswhere.

.NOTES
    - Run as Administrator
    - Requires internet access
    - Reboot may be needed depending on existing VS state
    - Estimated install size: ~2-4 GB depending on workloads selected
#>

[CmdletBinding()]
param(
    # Add extra workload IDs here if needed (e.g. "Microsoft.VisualStudio.Workload.WebBuildTools")
    [string[]]$ExtraWorkloads = @()
)

$ErrorActionPreference = 'Stop'

# ── Configuration ──────────────────────────────────────────────────────────────
$bootstrapperUrl  = 'https://aka.ms/vs/17/release/vs_buildtools.exe'
$installerPath    = Join-Path $env:TEMP 'vs_buildtools_2022.exe'
$installPath      = 'C:\BuildTools\VS2022'
$vswherePath      = "${env:ProgramFiles(x86)}\Microsoft Visual Studio\Installer\vswhere.exe"

# Core workloads — add more as needed for your projects
$workloads = @(
    'Microsoft.VisualStudio.Workload.MSBuildTools'        # MSBuild
    'Microsoft.VisualStudio.Workload.ManagedDesktopBuildTools'  # .NET desktop build support
    'Microsoft.VisualStudio.Workload.WebBuildTools'       # Web / ASP.NET build support
) + $ExtraWorkloads

# ── Download Bootstrapper ──────────────────────────────────────────────────────
Write-Host '>> Downloading VS 2022 Build Tools bootstrapper...' -ForegroundColor Cyan

# Use TLS 1.2+ (required on Server 2019)
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

try {
    Invoke-WebRequest -Uri $bootstrapperUrl -OutFile $installerPath -UseBasicParsing
    Write-Host "   Downloaded to: $installerPath"
}
catch {
    Write-Error "Failed to download bootstrapper: $_"
    exit 1
}

# ── Build Installer Arguments ──────────────────────────────────────────────────
$argList = @(
    '--quiet'
    '--wait'
    '--norestart'
    '--nocache'
    "--installPath `"$installPath`""
)

foreach ($wl in $workloads) {
    $argList += "--add $wl"
}

$argString = $argList -join ' '

Write-Host '>> Starting silent install (this may take 10-30 minutes)...' -ForegroundColor Cyan
Write-Host "   Install path : $installPath"
Write-Host "   Workloads    : $($workloads -join ', ')"

# ── Run Installer ──────────────────────────────────────────────────────────────
$process = Start-Process -FilePath $installerPath `
                         -ArgumentList $argString `
                         -Wait `
                         -PassThru `
                         -NoNewWindow

$exitCode = $process.ExitCode

# Exit codes: 0 = success, 3010 = success but reboot required
if ($exitCode -eq 0) {
    Write-Host '>> Install completed successfully.' -ForegroundColor Green
}
elseif ($exitCode -eq 3010) {
    Write-Host '>> Install completed successfully (reboot required).' -ForegroundColor Yellow
}
else {
    Write-Error ">> Install failed with exit code: $exitCode"
    Write-Error "   Check logs at: $env:TEMP\dd_*.log"
    exit $exitCode
}

# ── Validate MSBuild via vswhere ───────────────────────────────────────────────
Write-Host "`n>> Validating MSBuild 17 installation..." -ForegroundColor Cyan

# vswhere may have been installed/updated by the bootstrapper
if (-not (Test-Path $vswherePath)) {
    # Fallback: check PATH or known location
    $vswherePath = (Get-Command vswhere.exe -ErrorAction SilentlyContinue).Source
}

if ($vswherePath -and (Test-Path $vswherePath)) {
    $msbuildPath = & $vswherePath -latest -requires Microsoft.Component.MSBuild `
                                  -find 'MSBuild\**\Bin\MSBuild.exe' `
                                  -products * 2>$null | Select-Object -First 1

    if ($msbuildPath) {
        Write-Host "   Found MSBuild at: $msbuildPath" -ForegroundColor Green

        # Print version
        $versionOutput = & $msbuildPath -version -nologo 2>&1
        Write-Host "   MSBuild version: $versionOutput"
    }
    else {
        Write-Warning '   vswhere ran but could not locate MSBuild.exe'
        Write-Warning "   Try checking: $installPath\MSBuild\Current\Bin\MSBuild.exe"
    }
}
else {
    Write-Warning '   vswhere.exe not found — skipping auto-detection.'
    Write-Warning "   MSBuild should be at: $installPath\MSBuild\Current\Bin\MSBuild.exe"
}

# ── Clean up ───────────────────────────────────────────────────────────────────
Remove-Item -Path $installerPath -Force -ErrorAction SilentlyContinue

Write-Host "`n>> Done. You can now reference MSBuild 17 in your GitHub Actions workflows." -ForegroundColor Cyan
Write-Host '   Example setup-msbuild usage:'
Write-Host '     - uses: microsoft/setup-msbuild@v2'
Write-Host '       with:'
Write-Host "         vs-version: '[17.0,]'"
Write-Host ''
