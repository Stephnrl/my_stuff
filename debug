        x: 100 + (i % 4) * (NODE_W + 60) + (Math.random() * 20 - 10),
        y: y + Math.floor(i / 4) * (NODE_H + 50),
      };
    });
    if (items.length) y += Math.ceil(items.length / 4) * (NODE_H + 50) + 40;
  });

  // Simple force simulation (runs synchronously)
  const iterations = 120;
  for (let iter = 0; iter < iterations; iter++) {
    const alpha = 1 - iter / iterations;
    // Repulsion between all nodes
    for (let i = 0; i < NODES.length; i++) {
      for (let j = i + 1; j < NODES.length; j++) {
        const a = nodePositions[NODES[i].id];
        const b = nodePositions[NODES[j].id];
        let dx = b.x - a.x, dy = b.y - a.y;
        let dist = Math.sqrt(dx * dx + dy * dy) || 1;
        let force = 8000 / (dist * dist) * alpha;
        if (dist < NODE_W + 40) force *= 3;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.x -= fx; a.y -= fy;
        b.x += fx; b.y += fy;
      }
    }
    // Attraction along edges
    EDGES.forEach(e => {
      const a = nodePositions[e.from];
      const b = nodePositions[e.to];
      if (!a || !b) return;
      let dx = b.x - a.x, dy = b.y - a.y;
      let dist = Math.sqrt(dx * dx + dy * dy) || 1;
      let force = (dist - 200) * 0.02 * alpha;
      const fx = (dx / dist) * force;
      const fy = (dy / dist) * force;
      a.x += fx; a.y += fy;
      b.x -= fx; b.y -= fy;
    });
  }
}

// ═══ RENDER ════════════════════════════════════════════════════════════
function render() {
  const svg = document.getElementById('graphSvg');
  // Remove old content (keep defs)
  svg.querySelectorAll('.edge-line, .node-group').forEach(el => el.remove());

  const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  g.id = 'worldGroup';
  g.setAttribute('transform', `translate(${transform.x},${transform.y}) scale(${transform.k})`);

  // Edges
  EDGES.forEach(e => {
    const a = nodePositions[e.from];
    const b = nodePositions[e.to];
    if (!a || !b) return;

    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.classList.add('edge-line');
    line.dataset.from = e.from;
    line.dataset.to = e.to;
    line.setAttribute('x1', a.x + NODE_W / 2);
    line.setAttribute('y1', a.y + NODE_H / 2);
    line.setAttribute('x2', b.x + NODE_W / 2);
    line.setAttribute('y2', b.y + NODE_H / 2);
    g.appendChild(line);
  });

  // Nodes
  NODES.forEach(n => {
    const pos = nodePositions[n.id];
    if (!pos) return;
    const ng = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    ng.classList.add('node-group');
    ng.dataset.id = n.id;
    ng.setAttribute('transform', `translate(${pos.x}, ${pos.y})`);

    // Body rect
    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.classList.add('node-body');
    rect.setAttribute('width', NODE_W);
    rect.setAttribute('height', NODE_H);
    rect.setAttribute('fill', n.color + '18');
    rect.setAttribute('stroke', n.color + '40');
    rect.setAttribute('stroke-width', '1');
    ng.appendChild(rect);

    // Color accent bar
    const bar = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    bar.setAttribute('width', '4');
    bar.setAttribute('height', NODE_H);
    bar.setAttribute('fill', n.color);
    bar.setAttribute('rx', '2');
    ng.appendChild(bar);

    // Icon
    const icon = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    icon.classList.add('node-icon');
    icon.setAttribute('x', 22);
    icon.setAttribute('y', NODE_H / 2);
    icon.textContent = n.icon;
    ng.appendChild(icon);

    // Label
    const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    label.classList.add('node-label');
    label.setAttribute('x', 40);
    label.setAttribute('y', NODE_H / 2 - 6);
    label.textContent = n.label.length > 22 ? n.label.slice(0, 20) + '…' : n.label;
    ng.appendChild(label);

    // Type
    const typ = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    typ.classList.add('node-type');
    typ.setAttribute('x', 40);
    typ.setAttribute('y', NODE_H / 2 + 10);
    typ.textContent = n.type;
    ng.appendChild(typ);

    // Events
    ng.addEventListener('click', (ev) => { ev.stopPropagation(); selectNode(n.id); });
    ng.addEventListener('mouseenter', (ev) => showTooltip(ev, n));
    ng.addEventListener('mouseleave', hideTooltip);
    ng.addEventListener('mousedown', (ev) => startDragNode(ev, n.id));

    g.appendChild(ng);
  });

  svg.appendChild(g);
  applyFilters();
}

function updateTransform() {
  const g = document.getElementById('worldGroup');
  if (g) g.setAttribute('transform', `translate(${transform.x},${transform.y}) scale(${transform.k})`);
}

// ═══ INTERACTION ═══════════════════════════════════════════════════════
function selectNode(id) {
  selectedNodeId = id;
  document.querySelectorAll('.node-group').forEach(g => {
    g.classList.toggle('selected', g.dataset.id === id);
  });
  document.querySelectorAll('.res-item').forEach(el => {
    el.classList.toggle('active', el.dataset.id === id);
  });
  highlightConnections(id);
  openDetail(id);
}

function highlightConnections(id) {
  const connected = new Set([id]);
  EDGES.forEach(e => {
    if (e.from === id) connected.add(e.to);
    if (e.to === id) connected.add(e.from);
  });
  document.querySelectorAll('.node-group').forEach(g => {
    g.classList.toggle('dimmed', !connected.has(g.dataset.id));
  });
  document.querySelectorAll('.edge-line').forEach(l => {
    const from = l.dataset.from, to = l.dataset.to;
    const isConn = (from === id || to === id);
    l.classList.toggle('highlight', isConn);
    l.classList.toggle('dimmed', !isConn);
    if (isConn) l.setAttribute('marker-end', 'url(#arrowhead-hl)');
    else l.setAttribute('marker-end', 'url(#arrowhead)');
  });
}

function clearHighlights() {
  selectedNodeId = null;
  document.querySelectorAll('.node-group').forEach(g => {
    g.classList.remove('selected', 'dimmed');
  });
  document.querySelectorAll('.edge-line').forEach(l => {
    l.classList.remove('highlight', 'dimmed');
    l.setAttribute('marker-end', 'url(#arrowhead)');
  });
  document.querySelectorAll('.res-item').forEach(el => el.classList.remove('active'));
  closeDetail();
}

// Tooltip
function showTooltip(ev, node) {
  const tt = document.getElementById('tooltip');
  document.getElementById('ttTitle').textContent = node.label;
  document.getElementById('ttType').textContent = node.type;
  tt.classList.add('show');
  tt.style.left = (ev.clientX + 12) + 'px';
  tt.style.top  = (ev.clientY + 12) + 'px';
}
function hideTooltip() {
  document.getElementById('tooltip').classList.remove('show');
}

// Detail panel
function openDetail(id) {
  const node = NODES.find(n => n.id === id);
  if (!node) return;
  document.getElementById('detailIcon').textContent = node.icon;
  document.getElementById('detailName').textContent = node.label;
  document.getElementById('detailType').textContent = node.type;

  let html = '';

  // Details
  if (node.details.length) {
    html += '<div class="detail-section"><h4>Properties</h4>';
    node.details.forEach(d => {
      const [k, ...rest] = d.split(': ');
      html += `<div class="detail-row"><span class="dk">${k}</span><span class="dv">${rest.join(': ')}</span></div>`;
    });
    html += '</div>';
  }

  // Dependencies
  const deps = EDGES.filter(e => e.to === id).map(e => e.from);
  if (deps.length) {
    html += '<div class="detail-section"><h4>Depends On</h4>';
    deps.forEach(d => { html += `<a class="dep-link" onclick="selectNode('${d}')">${d}</a><br/>`; });
    html += '</div>';
  }

  // Dependents
  const dependents = EDGES.filter(e => e.from === id).map(e => e.to);
  if (dependents.length) {
    html += '<div class="detail-section"><h4>Used By</h4>';
    dependents.forEach(d => { html += `<a class="dep-link" onclick="selectNode('${d}')">${d}</a><br/>`; });
    html += '</div>';
  }

  // Attributes
  if (node.attrs && Object.keys(node.attrs).length) {
    html += '<div class="detail-section"><h4>Attributes</h4>';
    Object.entries(node.attrs).forEach(([k, v]) => {
      let vs = typeof v === 'object' ? JSON.stringify(v) : String(v);
      if (vs.length > 60) vs = vs.slice(0, 57) + '…';
      html += `<div class="detail-row"><span class="dk">${k}</span><span class="dv">${vs}</span></div>`;
    });
    html += '</div>';
  }

  document.getElementById('detailBody').innerHTML = html;
  document.getElementById('detailPanel').classList.add('open');
}
function closeDetail() {
  document.getElementById('detailPanel').classList.remove('open');
}

// Drag node
function startDragNode(ev, id) {
  if (ev.button !== 0) return;
  ev.stopPropagation();
  dragging = { id, startX: ev.clientX, startY: ev.clientY, origX: nodePositions[id].x, origY: nodePositions[id].y };
}
window.addEventListener('mousemove', ev => {
  if (dragging) {
    const dx = (ev.clientX - dragging.startX) / transform.k;
    const dy = (ev.clientY - dragging.startY) / transform.k;
    nodePositions[dragging.id].x = dragging.origX + dx;
    nodePositions[dragging.id].y = dragging.origY + dy;
    render();
    if (selectedNodeId === dragging.id) selectNode(dragging.id);
  }
  if (panning) {
    transform.x = panStart.tx + (ev.clientX - panStart.mx);
    transform.y = panStart.ty + (ev.clientY - panStart.my);
    updateTransform();
  }
});
window.addEventListener('mouseup', () => { dragging = null; panning = false; });

// Pan
const canvasArea = document.getElementById('canvasArea');
canvasArea.addEventListener('mousedown', ev => {
  if (ev.target.closest('.node-group') || ev.target.closest('.ctrl-btn')) return;
  panning = true;
  panStart = { mx: ev.clientX, my: ev.clientY, tx: transform.x, ty: transform.y };
  clearHighlights();
});

// Zoom
canvasArea.addEventListener('wheel', ev => {
  ev.preventDefault();
  const delta = ev.deltaY > 0 ? 0.9 : 1.1;
  const rect = canvasArea.getBoundingClientRect();
  const cx = ev.clientX - rect.left;
  const cy = ev.clientY - rect.top;
  transform.x = cx - (cx - transform.x) * delta;
  transform.y = cy - (cy - transform.y) * delta;
  transform.k *= delta;
  transform.k = Math.max(0.15, Math.min(3, transform.k));
  updateTransform();
}, { passive: false });

function zoomIn()  { transform.k = Math.min(3, transform.k * 1.2); updateTransform(); }
function zoomOut() { transform.k = Math.max(0.15, transform.k / 1.2); updateTransform(); }
function resetView() {
  // Fit all nodes
  let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
  NODES.forEach(n => {
    const p = nodePositions[n.id];
    if (!p) return;
    minX = Math.min(minX, p.x); minY = Math.min(minY, p.y);
    maxX = Math.max(maxX, p.x + NODE_W); maxY = Math.max(maxY, p.y + NODE_H);
  });
  const rect = canvasArea.getBoundingClientRect();
  const gw = maxX - minX + 100, gh = maxY - minY + 100;
  const k = Math.min(rect.width / gw, rect.height / gh, 1.5);
  transform.k = k;
  transform.x = (rect.width - gw * k) / 2 - minX * k + 50 * k;
  transform.y = (rect.height - gh * k) / 2 - minY * k + 50 * k;
  updateTransform();
}

// ═══ SIDEBAR ══════════════════════════════════════════════════════════
function buildSidebar() {
  // Pills
  const pills = document.getElementById('pills');
  pills.innerHTML = `
    <span class="pill">TF <b>v${META.terraform_version}</b></span>
    <span class="pill">Serial <b>#${META.serial}</b></span>
    <span class="pill">Resources <b>${META.resource_count}</b></span>
    <span class="pill">Edges <b>${META.edge_count}</b></span>
  `;

  // Legend
  const legend = document.getElementById('legend');
  Object.entries(CAT_COLORS).forEach(([cat, color]) => {
    const count = CAT_COUNTS[cat] || 0;
    if (!count) return;
    const item = document.createElement('div');
    item.className = 'legend-item';
    item.dataset.cat = cat;
    item.innerHTML = `<span class="legend-dot" style="background:${color}"></span>
      <span class="legend-label">${cat}</span>
      <span class="legend-count">${count}</span>`;
    item.addEventListener('click', () => toggleCategory(cat));
    legend.appendChild(item);
  });

  // Resource list
  const list = document.getElementById('resourceList');
  NODES.forEach(n => {
    const item = document.createElement('div');
    item.className = 'res-item';
    item.dataset.id = n.id;
    item.dataset.cat = n.category;
    item.innerHTML = `<span class="res-icon">${n.icon}</span>
      <span class="res-label">${n.label}</span>
      <span class="res-type">${n.type.replace('aws_','')}</span>`;
    item.addEventListener('click', () => {
      selectNode(n.id);
      // Pan to node
      const p = nodePositions[n.id];
      const rect = canvasArea.getBoundingClientRect();
      transform.x = rect.width / 2 - (p.x + NODE_W / 2) * transform.k;
      transform.y = rect.height / 2 - (p.y + NODE_H / 2) * transform.k;
      updateTransform();
    });
    list.appendChild(item);
  });
}

// Search
document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.res-item').forEach(el => {
    const id = el.dataset.id;
    const node = NODES.find(n => n.id === id);
    const match = !q || id.toLowerCase().includes(q) || node.label.toLowerCase().includes(q);
    el.classList.toggle('hidden', !match);
  });
});

// Category filter
function toggleCategory(cat) {
  if (activeCategories.has(cat)) activeCategories.delete(cat);
  else activeCategories.add(cat);
  applyFilters();
}

function applyFilters() {
  document.querySelectorAll('.legend-item').forEach(el => {
    el.classList.toggle('dimmed', !activeCategories.has(el.dataset.cat));
  });
  document.querySelectorAll('.node-group').forEach(g => {
    const node = NODES.find(n => n.id === g.dataset.id);
    if (node) g.style.display = activeCategories.has(node.category) ? '' : 'none';
  });
  document.querySelectorAll('.edge-line').forEach(l => {
    const fromNode = NODES.find(n => n.id === l.dataset.from);
    const toNode   = NODES.find(n => n.id === l.dataset.to);
    const vis = fromNode && toNode && activeCategories.has(fromNode.category) && activeCategories.has(toNode.category);
    l.style.display = vis ? '' : 'none';
  });
  document.querySelectorAll('.res-item').forEach(el => {
    if (!activeCategories.has(el.dataset.cat)) el.classList.add('hidden');
    else el.classList.remove('hidden');
  });
}

// ═══ INIT ══════════════════════════════════════════════════════════════
layoutGraph();
buildSidebar();
render();
requestAnimationFrame(() => resetView());
</script>
</body>
