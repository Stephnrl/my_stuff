# ─── Terraform Parser ───────────────────────────────────────────────────────────

def find_tf_files(root_dir: str) -> list[Path]:
    """Recursively find all .tf files, skipping .terraform directories."""
    tf_files = []
    for dirpath, dirnames, filenames in os.walk(root_dir):
        dirnames[:] = [d for d in dirnames if d != ".terraform"]
        for f in filenames:
            if f.endswith(".tf"):
                tf_files.append(Path(dirpath) / f)
    return sorted(tf_files)


def parse_tf_resources(tf_files: list[Path]) -> list[dict]:
    """
    Parse resource blocks from .tf files using regex.
    Returns list of dicts: {type, name, body, file, module_path}
    """
    # Matches: resource "aws_vpc" "main" { ... }
    resource_re = re.compile(
        r'resource\s+"([^"]+)"\s+"([^"]+)"\s*\{', re.MULTILINE
    )
    # Matches: module "vpc" { source = "..." }
    module_re = re.compile(
        r'module\s+"([^"]+)"\s*\{', re.MULTILINE
    )

    resources = []

    for tf_file in tf_files:
        content = tf_file.read_text(errors="replace")
        rel_path = tf_file.parent.name or "root"

        # Extract resources
        for match in resource_re.finditer(content):
            res_type = match.group(1)
            res_name = match.group(2)

            # Extract the body (find matching closing brace)
            body_start = match.end()
            body = _extract_block(content, body_start)

            resources.append({
                "type": res_type,
                "name": res_name,
                "body": body,
                "file": str(tf_file),
                "module_path": rel_path,
            })

    return resources


def _extract_block(content: str, start: int) -> str:
    """Extract a {} block from content starting after the opening brace."""
    depth = 1
    i = start
    while i < len(content) and depth > 0:
        if content[i] == "{":
            depth += 1
        elif content[i] == "}":
            depth -= 1
        i += 1
    return content[start:i - 1]


def classify_subnet(resource: dict) -> type:
    """Determine if a subnet is public or private based on common heuristics."""
    body = resource["body"].lower()
    name = resource["name"].lower()

    # Check for map_public_ip_on_launch = true
    if re.search(r'map_public_ip_on_launch\s*=\s*true', body):
        return PublicSubnet

    # Check naming conventions
    if any(kw in name for kw in ["public", "pub", "dmz", "external"]):
        return PublicSubnet
    if any(kw in name for kw in ["private", "priv", "internal", "app", "data", "db"]):
        return PrivateSubnet

    # Check tags
    if re.search(r'(name|Name).*public', body):
        return PublicSubnet
    if re.search(r'(name|Name).*private', body):
        return PrivateSubnet

    return PrivateSubnet  # default to private


def extract_vpc_references(resource: dict) -> str | None:
    """Try to find which VPC a resource belongs to via vpc_id references."""
    body = resource["body"]
    # Match vpc_id = aws_vpc.main.id or var.vpc_id or module.vpc.id patterns
    m = re.search(r'vpc_id\s*=\s*(?:aws_vpc\.(\w+)\.id|(\S+))', body)
    if m:
        return m.group(1) or m.group(2)
    return None


def extract_endpoint_service(resource: dict) -> str:
    """Extract the service name from a VPC endpoint."""
    body = resource["body"]
    m = re.search(r'service_name\s*=\s*"?([^"\s]+)"?', body)
    if m:
        svc = m.group(1)
        # Extract just the service part: com.amazonaws.region.s3 -> s3
        parts = svc.split(".")
        return parts[-1] if parts else svc
    return ""


# ─── Diagram Generator ──────────────────────────────────────────────────────────

def build_label(resource: dict, mapping: tuple) -> str:
    """Build a clean label for a diagram node."""
    friendly = mapping[2] if mapping else resource["type"]
    name = resource["name"].replace("_", " ").replace("-", " ").title()

    # For endpoints, append the service name
    if resource["type"] == "aws_vpc_endpoint":
        svc = extract_endpoint_service(resource)
        if svc:
            return f"{friendly}\n({svc})"

    return f"{friendly}\n{name}"


def generate_diagram(
    resources: list[dict],
    output_name: str = "aws_network_diagram",
    output_format: str = "png",
    show_all: bool = False,
    direction: str = "TB",
):
    """Generate the architecture diagram from parsed resources."""

    # Filter to mapped resources only
    mapped = []
    unmapped_types = set()
    for r in resources:
        if r["type"] in RESOURCE_MAP:
            mapping = RESOURCE_MAP[r["type"]]
            if mapping[0] is not None:  # skip noise resources (routes, rules, etc.)
                mapped.append(r)
        elif show_all and r["type"].startswith("aws_"):
            mapped.append(r)
        else:
            unmapped_types.add(r["type"])

    if not mapped:
        print("⚠️  No diagrammable resources found. Check your Terraform path.")
        print(f"   Found {len(resources)} total resources, types: {sorted(set(r['type'] for r in resources))}")
        sys.exit(1)

    # Group resources by category
    vpcs = [r for r in mapped if r["type"] in ("aws_vpc", "aws_default_vpc")]
    subnets = [r for r in mapped if r["type"] in ("aws_subnet", "aws_default_subnet")]
    endpoints = [r for r in mapped if r["type"] in ("aws_vpc_endpoint",)]
    gateways = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "gateway"]
    tgw_resources = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "tgw"]
    flowlogs = [r for r in mapped if r["type"] == "aws_flow_log"]
    route_tables = [r for r in mapped if r["type"] in ("aws_route_table", "aws_default_route_table")]
    security = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "security"]
    dns = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "dns"]
    lb = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "lb"]
    monitoring = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "monitoring"]
    storage = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "storage"]
    peering = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "peering"]
    firewall = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "firewall"]
    cdn = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "cdn"]
    dx = [r for r in mapped if RESOURCE_MAP.get(r["type"], (None, ""))[1] == "dx"]

    # Separate public vs private subnets
    public_subnets = [s for s in subnets if classify_subnet(s) == PublicSubnet]
    private_subnets = [s for s in subnets if classify_subnet(s) == PrivateSubnet]

    # ── Build Diagram ──
    graph_attr = {
        "fontsize": "14",
        "bgcolor": "white",
        "pad": "0.5",
        "nodesep": "0.8",
        "ranksep": "1.0",
    }

    node_attr = {
        "fontsize": "11",
    }

    with Diagram(
        output_name.replace("_", " ").title(),
        filename=output_name,
        outformat=output_format,
        direction=direction,
        show=False,
        graph_attr=graph_attr,
        node_attr=node_attr,
    ):
        # Nodes we'll store for edges
        nodes = {}

        def make_node(resource, cls_override=None):
            mapping = RESOURCE_MAP.get(resource["type"])
            cls = cls_override or (mapping[0] if mapping else General)
            label = build_label(resource, mapping)
            key = f"{resource['type']}.{resource['name']}"
            node = cls(label)
            nodes[key] = node
            return node

        # ── Internet / External ──
        # CDN and DNS at the top
        cdn_nodes = [make_node(r) for r in cdn]
        dns_nodes = [make_node(r) for r in dns]

        # ── Gateways (outside VPC clusters) ──
        igw_nodes = [make_node(r) for r in gateways if "internet_gateway" in r["type"]]

        # ── VPC clusters ──
        if vpcs:
            for vpc_res in vpcs:
                vpc_label = f"VPC: {vpc_res['name'].replace('_', ' ').title()}"
                with Cluster(vpc_label):

                    vpc_node = make_node(vpc_res)

                    # Public subnets cluster
                    pub_nodes = []
                    if public_subnets:
                        with Cluster("Public Subnets", graph_attr={"bgcolor": "#e8f5e9", "style": "rounded"}):
                            for s in public_subnets:
                                pub_nodes.append(make_node(s, PublicSubnet))

                    # Private subnets cluster
                    priv_nodes = []
                    if private_subnets:
                        with Cluster("Private Subnets", graph_attr={"bgcolor": "#e3f2fd", "style": "rounded"}):
                            for s in private_subnets:
                                priv_nodes.append(make_node(s, PrivateSubnet))

                    # NAT Gateways
                    nat_nodes = [make_node(r) for r in gateways if "nat_gateway" in r["type"]]

                    # VPN Gateways
                    vpn_nodes = [make_node(r) for r in gateways
                                 if any(k in r["type"] for k in ["vpn_gateway", "vpn_connection", "customer_gateway", "client_vpn"])]

                    # Route Tables
                    rt_nodes = [make_node(r) for r in route_tables]

                    # VPC Endpoints cluster
                    ep_nodes = []
                    if endpoints:
                        with Cluster("VPC Endpoints", graph_attr={"bgcolor": "#fce4ec", "style": "rounded"}):
                            for e in endpoints:
                                ep_nodes.append(make_node(e))

                    # Network Firewall
                    fw_nodes = [make_node(r) for r in firewall]

                    # Load Balancers
                    lb_nodes = [make_node(r) for r in lb]

                    # Security (NACLs, SGs)
                    sec_nodes = [make_node(r) for r in security]

                    # ── Edges within VPC ──

                    # IGW -> public subnets
                    for igw in igw_nodes:
                        igw >> Edge(color="#4CAF50", style="bold") >> vpc_node
                        for pub in pub_nodes:
                            igw >> Edge(color="#4CAF50") >> pub

                    # NAT: public subnet -> NAT -> private subnet
                    for nat in nat_nodes:
                        for pub in pub_nodes[:1]:
                            pub >> Edge(color="#FF9800", label="NAT") >> nat
                        for priv in priv_nodes:
                            nat >> Edge(color="#FF9800") >> priv

                    # Route tables -> subnets
                    for rt in rt_nodes:
                        for pub in pub_nodes:
                            rt >> Edge(color="#9E9E9E", style="dashed") >> pub
                        for priv in priv_nodes:
                            rt >> Edge(color="#9E9E9E", style="dashed") >> priv

                    # Endpoints -> private subnets
                    for ep in ep_nodes:
                        for priv in priv_nodes[:1]:
                            priv >> Edge(color="#E91E63", style="dotted") >> ep

                    # Firewall in front
                    for fw in fw_nodes:
                        for igw in igw_nodes:
                            igw >> Edge(color="#F44336", label="inspect") >> fw

        else:
            # No VPCs found — just lay out flat
            for r in mapped:
                make_node(r)

        # ── Transit Gateway (outside VPC) ──
        if tgw_resources:
            with Cluster("Transit Gateway", graph_attr={"bgcolor": "#fff3e0", "style": "rounded"}):
                for r in tgw_resources:
                    make_node(r)

        # ── VPC Peering ──
        peer_nodes = [make_node(r) for r in peering]

        # ── Direct Connect ──
        if dx:
            with Cluster("Direct Connect", graph_attr={"bgcolor": "#f3e5f5", "style": "rounded"}):
                for r in dx:
                    make_node(r)

        # ── Monitoring / Flow Logs ──
        if flowlogs or monitoring or storage:
            with Cluster("Logging & Monitoring", graph_attr={"bgcolor": "#FFFDE7", "style": "rounded"}):
                fl_nodes = [make_node(r) for r in flowlogs]
                mon_nodes = [make_node(r) for r in monitoring]
                s3_nodes = [make_node(r) for r in storage]

                # Flow logs -> CW/S3
                for fl in fl_nodes:
                    for cw in mon_nodes:
                        fl >> Edge(color="#FFC107", style="dashed", label="logs") >> cw
                    for s3 in s3_nodes:
                        fl >> Edge(color="#FFC107", style="dashed", label="logs") >> s3

    # ── Summary ──
    output_file = f"{output_name}.{output_format}"
    print(f"\n✅ Diagram generated: {output_file}")
    print(f"   Resources diagrammed: {len(mapped)}")
    if unmapped_types:
        print(f"   Skipped resource types (not network-related): {len(unmapped_types)}")
        if len(unmapped_types) <= 10:
            for t in sorted(unmapped_types):
                print(f"     - {t}")

    return output_file


# ─── CLI ────────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Generate AWS networking diagram from Terraform code",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s ./infrastructure/networking
  %(prog)s ./terraform --output my_network --format svg
  %(prog)s ./modules --direction LR --show-all
        """,
    )
    parser.add_argument(
        "terraform_dir",
        help="Path to Terraform directory (scanned recursively)",
    )
    parser.add_argument(
        "--output", "-o",
        default="aws_network_diagram",
        help="Output filename without extension (default: aws_network_diagram)",
    )
    parser.add_argument(
        "--format", "-f",
        default="png",
        choices=["png", "svg", "pdf", "jpg"],
        help="Output format (default: png)",
    )
    parser.add_argument(
        "--direction", "-d",
        default="TB",
        choices=["TB", "BT", "LR", "RL"],
        help="Diagram direction: TB (top-bottom), LR (left-right), etc.",
    )
    parser.add_argument(
        "--show-all",
        action="store_true",
        help="Include unmapped AWS resources as generic nodes",
    )
    parser.add_argument(
        "--list-resources",
        action="store_true",
        help="Just list discovered resources without generating a diagram",
    )

    args = parser.parse_args()

    # Validate path
    tf_dir = Path(args.terraform_dir)
    if not tf_dir.is_dir():
        print(f"❌ Not a directory: {tf_dir}")
        sys.exit(1)

    # Find and parse
    tf_files = find_tf_files(str(tf_dir))
    if not tf_files:
        print(f"❌ No .tf files found in {tf_dir}")
        sys.exit(1)

    print(f"📂 Scanning {len(tf_files)} .tf files in {tf_dir}...")
    resources = parse_tf_resources(tf_files)
    print(f"🔍 Found {len(resources)} resource blocks")

    if args.list_resources:
        type_counts = defaultdict(int)
        for r in resources:
            type_counts[r["type"]] += 1
        print("\nResource types found:")
        for t, count in sorted(type_counts.items()):
            marker = "✓" if t in RESOURCE_MAP else " "
            print(f"  {marker} {t}: {count}")
        print(f"\n✓ = mapped to diagram node ({sum(1 for t in type_counts if t in RESOURCE_MAP)}/{len(type_counts)})")
        sys.exit(0)

    # Generate
    generate_diagram(
        resources,
        output_name=args.output,
        output_format=args.format,
        show_all=args.show_all,
        direction=args.direction,
    )


if __name__ == "__main__":
    main()
