def _import_node_class(category: str, class_name: str):
    """Dynamically import a diagrams node class."""
    import importlib
    mod = importlib.import_module(f"diagrams.aws.{category}")
    return getattr(mod, class_name)


def _deduplicate_resources(resources: list[TFResource]) -> list[TFResource]:
    """Keep one representative node per resource type in a directory."""
    seen = {}
    for r in resources:
        if r.resource_type not in seen:
            seen[r.resource_type] = r
    return list(seen.values())


def _pretty_label(resource: TFResource) -> str:
    """Human-readable label for a resource node."""
    # aws_nat_gateway -> NAT Gateway
    parts = resource.resource_type.replace("aws_", "").split("_")
    label = " ".join(p.upper() if len(p) <= 3 else p.capitalize() for p in parts)
    return label


def detect_profile(directories: list[ModuleDirectory]) -> str:
    """Auto-detect which profile to use based on directory names."""
    dir_names = {d.name.lower() for d in directories}
    all_resource_types = {r.resource_type for d in directories for r in d.resources}

    if any("eks" in rt for rt in all_resource_types):
        return "eks"
    if "vpc" in dir_names or any("vpc" in n for n in dir_names):
        return "vpc"
    return "generic"


def find_dir_by_substring(directories: list[ModuleDirectory], substring: str):
    """Find a ModuleDirectory whose name contains the substring."""
    for d in directories:
        if substring in d.name.lower():
            return d
    return None


def generate_diagram(
    module_path: str,
    output_name: str = "diagram",
    profile_name: str = "auto",
    out_format: str = "png",
):
    """Main entrypoint: scan, parse, and render the diagram."""
    from diagrams import Diagram, Cluster, Edge

    directories = scan_module(module_path)
    if not directories:
        print(f"No terraform directories with resources found in {module_path}")
        sys.exit(1)

    # Profile selection
    if profile_name == "auto":
        profile_name = detect_profile(directories)
        print(f"  Auto-detected profile: {profile_name}")

    profile = PROFILES.get(profile_name, {})
    title = profile.get("title", f"Terraform Module: {os.path.basename(module_path)}")
    direction = profile.get("direction", "TB")
    cluster_order = profile.get("cluster_order", [])
    connections = profile.get("connections", [])

    # Sort directories by profile order (unmatched go to the end)
    def sort_key(d):
        for i, pattern in enumerate(cluster_order):
            if pattern in d.name.lower():
                return i
        return 999

    directories.sort(key=sort_key)

    # Print what we found
    print(f"\n  Module: {module_path}")
    print(f"  Profile: {profile_name} | Direction: {direction}")
    print(f"  Directories found: {len(directories)}\n")
    for d in directories:
        types = [r.resource_type for r in d.resources]
        print(f"    {d.name:25s} -> {types}")
    print()

    # Build diagram
    graph_attr = {
        "fontsize": "14",
        "bgcolor": "white",
        "pad": "0.5",
        "nodesep": "0.8",
        "ranksep": "1.0",
    }

    cluster_nodes = {}  # dir_name -> list of diagram nodes

    with Diagram(
        title,
        filename=output_name,
        outformat=out_format,
        direction=direction,
        show=False,
        graph_attr=graph_attr,
    ):
        for mod_dir in directories:
            cluster_label = mod_dir.name.replace("-", " ").title()
            unique_resources = _deduplicate_resources(mod_dir.resources)

            with Cluster(cluster_label):
                nodes = []
                for res in unique_resources:
                    registry_entry = RESOURCE_REGISTRY.get(res.resource_type)
                    if registry_entry:
                        category, class_name = registry_entry
                        NodeClass = _import_node_class(category, class_name)
                        node = NodeClass(_pretty_label(res))
                    else:
                        # Fallback: generic node with the raw type name
                        from diagrams.aws.general import General
                        node = General(res.resource_type.replace("aws_", ""))
                    nodes.append(node)

                cluster_nodes[mod_dir.name] = nodes

        # Draw inter-cluster connections
        for src_pattern, dst_pattern in connections:
            src_dir = find_dir_by_substring(directories, src_pattern)
            dst_dir = find_dir_by_substring(directories, dst_pattern)
            if src_dir and dst_dir:
                src_nodes = cluster_nodes.get(src_dir.name, [])
                dst_nodes = cluster_nodes.get(dst_dir.name, [])
                if src_nodes and dst_nodes:
                    # Connect the first node of each cluster (representative)
                    src_nodes[0] >> Edge(color="#666666", style="dashed") >> dst_nodes[0]

    print(f"  Diagram saved: {output_name}.{out_format}")


# ──────────────────────────────────────────────────────────────
# CLI
# ──────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Generate architecture diagrams from Terraform module directories.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Auto-detect profile from resource types
  python3 tf_diagram.py ./terraform-vpc-module

  # Specify profile and output
  python3 tf_diagram.py ./terraform-eks-module --profile eks --output eks-arch

  # List known profiles
  python3 tf_diagram.py --list-profiles

  # Audit: find unmapped resource types before generating
  python3 tf_diagram.py ./terraform-vpc-module --audit
        """,
    )
    parser.add_argument("module_path", nargs="?", help="Path to the Terraform module root")
    parser.add_argument("--output", "-o", default="diagram", help="Output filename (no extension)")
    parser.add_argument("--profile", "-p", default="auto", help="Profile name or 'auto'")
    parser.add_argument("--format", "-f", default="png", choices=["png", "jpg", "svg", "pdf"])
    parser.add_argument("--list-profiles", action="store_true", help="Show available profiles")
    parser.add_argument("--list-resources", action="store_true", help="Show supported resource types")
    parser.add_argument("--audit", action="store_true",
                        help="Scan module and report unmapped resource types")

    args = parser.parse_args()

    if args.list_profiles:
        print("\nAvailable profiles:\n")
        for name, cfg in PROFILES.items():
            print(f"  {name:12s}  {cfg.get('title', 'N/A')}")
            if cfg.get("cluster_order"):
                print(f"{'':14s}  directories: {', '.join(cfg['cluster_order'])}")
            print()
        return

    if args.list_resources:
        print("\nSupported Terraform resource types:\n")
        for res_type, (cat, cls) in sorted(RESOURCE_REGISTRY.items()):
            print(f"  {res_type:45s} -> diagrams.aws.{cat}.{cls}")
        print(f"\n  Total: {len(RESOURCE_REGISTRY)} resource types")
        return

    if not args.module_path:
        parser.print_help()
        sys.exit(1)

    if args.audit:
        audit_module(args.module_path)
        return

    generate_diagram(
        module_path=args.module_path,
        output_name=args.output,
        profile_name=args.profile,
        out_format=args.format,
    )


if __name__ == "__main__":
    main()
