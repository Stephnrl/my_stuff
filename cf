    Value: !GetAtt GitHubOIDCProvider.Arn

  NonProdRoleArn:
    Description: IAM role ARN for nonprod GitHub Actions workflows.
    Value: !GetAtt NonProdDeployRole.Arn

  ProdRoleArn:
    Description: IAM role ARN for prod GitHub Actions workflows.
    Value: !GetAtt ProdDeployRole.Arn

  TfStateBucketName:
    Description: S3 bucket name for Terraform remote state.
    Value: !Ref TfStateBucket

  TfStateBucketArn:
    Description: S3 bucket ARN for Terraform remote state.
    Value: !GetAtt TfStateBucket.Arn

  TfLockTableName:
    Description: DynamoDB table name for Terraform state locking.
    Value: !Ref TfLockTable

  TfStateKmsKeyArn:
    Description: KMS CMK ARN used for Terraform state encryption.
    Value: !GetAtt TfStateKmsKey.Arn

  TfStateAccessLogsBucketName:
