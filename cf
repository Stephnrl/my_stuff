AWSTemplateFormatVersion: "2010-09-09"
Description: >
  Bootstrap stack — GitHub Actions OIDC provider, nonprod/prod IAM roles,
  Terraform state S3 bucket, and DynamoDB state-lock table.
  GovCloud-compatible (uses AWS::Partition for all ARNs).

# ──────────────────────────────────────────────
# Parameters
# ──────────────────────────────────────────────
Parameters:

  # ── Bootstrap-specific ─────────────────────
  GitHubOrg:
    Type: String
    Description: GitHub organization or user name.

  GitHubRepo:
    Type: String
    Description: GitHub repository name (without org prefix).

  NonProdEnvironment:
    Type: String
    Default: nonprod
    Description: GitHub Actions environment name for non-production deployments.

  ProdEnvironment:
    Type: String
    Default: prod
    Description: GitHub Actions environment name for production deployments.

  TfStateBucketName:
    Type: String
    Description: >
      Globally unique name for the Terraform state S3 bucket.
      Example: myorg-terraform-state

  TfLockTableName:
    Type: String
    Default: terraform-state-lock
    Description: DynamoDB table name used for Terraform state locking.

  PermissionsBoundaryArn:
    Type: String
    Default: ""
    Description: >
      (Optional) ARN of an IAM permissions boundary to attach to both roles.
      Leave blank to skip.

  # ── Tagging — Organizational ───────────────
  TagEnvironment:
    Type: String
    AllowedValues: [dev, test, staging, nonprod, prod, shared-services]
    Description: "Tag: environment"

  TagProjectName:
    Type: String
    Description: "Tag: project_name"

  TagApplicationName:
    Type: String
    Description: "Tag: application_name"

  TagChargeNumber:
    Type: String
    Description: "Tag: charge_number"

  TagAccountId:
    Type: String
    Description: "Tag: account_id — logical account identifier (not necessarily the AWS account ID)"

  TagOrgId:
    Type: String
    Description: "Tag: org_id"

  TagBusinessUnit:
    Type: String
    Description: "Tag: business_unit"

  TagBusinessArea:
    Type: String
    Description: "Tag: business_area"

  TagResponsibleTeam:
    Type: String
    Description: "Tag: responsible_team"

  # ── Tagging — Financial ────────────────────
  TagFinancialCategory:
    Type: String
    Description: "Tag: financial_category"

  # ── Tagging — Security & Compliance ────────
  TagConfidentiality:
    Type: String
    AllowedValues: [public, internal, confidential, restricted]
    Default: restricted
    Description: "Tag: confidentiality"

  TagExportControlled:
    Type: String
    AllowedValues: ["true", "false"]
    Default: "false"
    Description: "Tag: export_controlled"

  TagCuiClassification:
    Type: String
    Default: ""
    Description: "Tag: cui_classification (e.g. CUI//SP-CTI, CUI//SP-EXPT, N/A)"

  TagCompliance:
    Type: String
    Default: cmmc-l2
    Description: "Tag: compliance (e.g. cmmc-l2, nist-800-171, fedramp-moderate)"

  # ── Tagging — Lifecycle ────────────────────
  TagExpectedEolDate:
    Type: String
    Default: ""
    Description: "Tag: expected_eol_date (ISO 8601, e.g. 2027-12-31)"

  # ── Tagging — Architecture Tiering ─────────
  TagBusinessTier:
    Type: String
    Default: ""
    Description: "Tag: business_tier (e.g. mission-critical, business-operational, administrative)"

  TagSecurityTier:
    Type: String
    Default: ""
    Description: "Tag: security_tier (e.g. high, moderate, low)"

  TagLandingzoneName:
    Type: String
    Default: ""
    Description: "Tag: landingzone_name"

  # ── Tagging — Ownership ────────────────────
  TagBusinessOwner:
    Type: String
    Description: "Tag: business_owner (email or team name)"

  TagTechOwner:
    Type: String
    Description: "Tag: tech_owner (email or team name)"

  # ── Tagging — IaC ──────────────────────────
  TagSourceGithubProject:
    Type: String
    Description: "Tag: source_github_project (e.g. myorg/infra-security)"

  TagTerraformManaged:
    Type: String
    AllowedValues: ["true", "false"]
    Default: "true"
    Description: "Tag: terraform_managed"

Conditions:
  HasPermissionsBoundary: !Not [!Equals [!Ref PermissionsBoundaryArn, ""]]

Resources:

  # ──────────────────────────────────────────
  # 1. GitHub OIDC Identity Provider
  # ──────────────────────────────────────────
  GitHubOIDCProvider:
    Type: AWS::IAM::OIDCProvider
    Properties:
      Url: https://token.actions.githubusercontent.com
      ClientIdList:
        - sts.amazonaws.com
      ThumbprintList:
        - 6938fd4d98bab03faadb97b34396831e3780aea1
      Tags:
        - Key: environment
          Value: !Ref TagEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  # ──────────────────────────────────────────
  # 2. IAM Managed Policy — Security Tooling
  #    Note: AWS::IAM::ManagedPolicy does not
  #    support Tags in CloudFormation.
  # ──────────────────────────────────────────
  SecurityToolingDeployPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName: SecurityToolingDeploy
      Description: >
        Least-privilege policy for deploying and managing centralized
        security tooling (GuardDuty, Config, CloudTrail, Security Hub,
        IAM Access Analyzer) and their supporting resources via Terraform.
      PolicyDocument:
        Version: "2012-10-17"
        Statement:

          # ── GuardDuty ──────────────────────────
          - Sid: GuardDuty
            Effect: Allow
            Action:
              - guardduty:CreateDetector
              - guardduty:DeleteDetector
              - guardduty:GetDetector
              - guardduty:ListDetectors
              - guardduty:UpdateDetector
              - guardduty:CreateMembers
              - guardduty:DeleteMembers
              - guardduty:GetMembers
              - guardduty:ListMembers
              - guardduty:InviteMembers
              - guardduty:DisassociateMembers
              - guardduty:CreatePublishingDestination
              - guardduty:DeletePublishingDestination
              - guardduty:DescribePublishingDestination
              - guardduty:UpdatePublishingDestination
              - guardduty:ListPublishingDestinations
              - guardduty:GetMasterAccount
              - guardduty:GetAdministratorAccount
              - guardduty:EnableOrganizationAdminAccount
              - guardduty:DisableOrganizationAdminAccount
              - guardduty:ListOrganizationAdminAccounts
              - guardduty:DescribeOrganizationConfiguration
              - guardduty:UpdateOrganizationConfiguration
              - guardduty:CreateFilter
              - guardduty:DeleteFilter
              - guardduty:GetFilter
              - guardduty:ListFilters
              - guardduty:UpdateFilter
              - guardduty:GetFindings
              - guardduty:ListFindings
              - guardduty:GetFindingsStatistics
              - guardduty:TagResource
              - guardduty:UntagResource
              - guardduty:ListTagsForResource
            Resource: "*"

          # ── AWS Config ─────────────────────────
          - Sid: Config
            Effect: Allow
            Action:
              - config:PutConfigurationRecorder
              - config:DeleteConfigurationRecorder
              - config:DescribeConfigurationRecorders
              - config:DescribeConfigurationRecorderStatus
              - config:StartConfigurationRecorder
              - config:StopConfigurationRecorder
              - config:PutDeliveryChannel
              - config:DeleteDeliveryChannel
              - config:DescribeDeliveryChannels
              - config:DescribeDeliveryChannelStatus
              - config:PutConfigRule
              - config:DeleteConfigRule
              - config:DescribeConfigRules
              - config:DescribeConfigRuleEvaluationStatus
              - config:PutOrganizationConfigRule
              - config:DeleteOrganizationConfigRule
              - config:DescribeOrganizationConfigRules
              - config:DescribeOrganizationConfigRuleStatuses
              - config:PutConfigurationAggregator
              - config:DeleteConfigurationAggregator
              - config:DescribeConfigurationAggregators
              - config:DescribeAggregateComplianceByConfigRules
              - config:PutAggregationAuthorization
              - config:DeleteAggregationAuthorization
              - config:DescribeAggregationAuthorizations
              - config:PutConformancePack
              - config:DeleteConformancePack
              - config:DescribeConformancePacks
              - config:DescribeConformancePackCompliance
              - config:PutOrganizationConformancePack
              - config:DeleteOrganizationConformancePack
              - config:DescribeOrganizationConformancePacks
              - config:GetComplianceSummaryByConfigRule
              - config:GetComplianceSummaryByResourceType
              - config:GetComplianceDetailsByConfigRule
              - config:TagResource
              - config:UntagResource
              - config:ListTagsForResource
            Resource: "*"

          # ── CloudTrail ─────────────────────────
          - Sid: CloudTrail
            Effect: Allow
            Action:
              - cloudtrail:CreateTrail
              - cloudtrail:DeleteTrail
              - cloudtrail:GetTrail
              - cloudtrail:GetTrailStatus
              - cloudtrail:DescribeTrails
              - cloudtrail:UpdateTrail
              - cloudtrail:StartLogging
              - cloudtrail:StopLogging
              - cloudtrail:PutEventSelectors
              - cloudtrail:GetEventSelectors
              - cloudtrail:PutInsightSelectors
              - cloudtrail:GetInsightSelectors
              - cloudtrail:AddTags
              - cloudtrail:RemoveTags
              - cloudtrail:ListTags
            Resource: "*"

          # ── Security Hub ───────────────────────
          - Sid: SecurityHub
            Effect: Allow
            Action:
              - securityhub:EnableSecurityHub
              - securityhub:DisableSecurityHub
              - securityhub:DescribeHub
              - securityhub:UpdateSecurityHubConfiguration
              - securityhub:BatchEnableStandards
              - securityhub:BatchDisableStandards
              - securityhub:GetEnabledStandards
              - securityhub:DescribeStandards
              - securityhub:DescribeStandardsControls
              - securityhub:UpdateStandardsControl
              - securityhub:EnableOrganizationAdminAccount
              - securityhub:DisableOrganizationAdminAccount
              - securityhub:ListOrganizationAdminAccounts
              - securityhub:DescribeOrganizationConfiguration
              - securityhub:UpdateOrganizationConfiguration
              - securityhub:CreateMembers
              - securityhub:DeleteMembers
              - securityhub:GetMembers
              - securityhub:ListMembers
              - securityhub:InviteMembers
              - securityhub:DisassociateMembers
              - securityhub:CreateActionTarget
              - securityhub:DeleteActionTarget
              - securityhub:DescribeActionTargets
              - securityhub:UpdateActionTarget
              - securityhub:GetFindings
              - securityhub:BatchImportFindings
              - securityhub:BatchUpdateFindings
              - securityhub:TagResource
              - securityhub:UntagResource
              - securityhub:ListTagsForResource
            Resource: "*"

          # ── IAM Access Analyzer ────────────────
          - Sid: AccessAnalyzer
            Effect: Allow
            Action:
              - access-analyzer:CreateAnalyzer
              - access-analyzer:DeleteAnalyzer
              - access-analyzer:GetAnalyzer
              - access-analyzer:ListAnalyzers
              - access-analyzer:UpdateAnalyzer
              - access-analyzer:CreateArchiveRule
              - access-analyzer:DeleteArchiveRule
              - access-analyzer:GetArchiveRule
              - access-analyzer:ListArchiveRules
              - access-analyzer:UpdateArchiveRule
              - access-analyzer:TagResource
              - access-analyzer:UntagResource
              - access-analyzer:ListTagsForResource
            Resource: "*"

          # ── Organizations (read + delegated admin) ─
          - Sid: OrganizationsRead
            Effect: Allow
            Action:
              - organizations:DescribeOrganization
              - organizations:DescribeAccount
              - organizations:ListAccounts
              - organizations:ListRoots
              - organizations:ListChildren
              - organizations:ListDelegatedAdministrators
              - organizations:ListDelegatedServicesForAccount
              - organizations:ListAWSServiceAccessForOrganization
            Resource: "*"
          - Sid: OrganizationsServiceAccess
            Effect: Allow
            Action:
              - organizations:EnableAWSServiceAccess
              - organizations:DisableAWSServiceAccess
              - organizations:RegisterDelegatedAdministrator
              - organizations:DeregisterDelegatedAdministrator
            Resource: "*"

          # ── IAM — service-linked roles + scoped role/policy mgmt ─
          - Sid: IAMServiceLinkedRoles
            Effect: Allow
            Action:
              - iam:CreateServiceLinkedRole
              - iam:DeleteServiceLinkedRole
              - iam:GetServiceLinkedRoleDeletionStatus
            Resource:
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/aws-service-role/*
          - Sid: IAMRolesForSecurityServices
            Effect: Allow
            Action:
              - iam:CreateRole
              - iam:DeleteRole
              - iam:GetRole
              - iam:UpdateRole
              - iam:UpdateAssumeRolePolicy
              - iam:PassRole
              - iam:TagRole
              - iam:UntagRole
              - iam:ListRoleTags
              - iam:AttachRolePolicy
              - iam:DetachRolePolicy
              - iam:ListAttachedRolePolicies
              - iam:PutRolePolicy
              - iam:DeleteRolePolicy
              - iam:GetRolePolicy
              - iam:ListRolePolicies
              - iam:ListInstanceProfilesForRole
            Resource:
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/security-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/config-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/cloudtrail-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/guardduty-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/securityhub-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:role/access-analyzer-*
          - Sid: IAMPoliciesForSecurityServices
            Effect: Allow
            Action:
              - iam:CreatePolicy
              - iam:DeletePolicy
              - iam:GetPolicy
              - iam:GetPolicyVersion
              - iam:ListPolicyVersions
              - iam:CreatePolicyVersion
              - iam:DeletePolicyVersion
              - iam:SetDefaultPolicyVersion
              - iam:TagPolicy
              - iam:UntagPolicy
            Resource:
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/security-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/config-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/cloudtrail-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/guardduty-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/securityhub-*
              - !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:policy/access-analyzer-*

          # ── S3 — delivery buckets for Config/CloudTrail ─
          - Sid: S3DeliveryBuckets
            Effect: Allow
            Action:
              - s3:CreateBucket
              - s3:DeleteBucket
              - s3:GetBucketPolicy
              - s3:PutBucketPolicy
              - s3:DeleteBucketPolicy
              - s3:GetBucketAcl
              - s3:PutBucketAcl
              - s3:GetBucketVersioning
              - s3:PutBucketVersioning
              - s3:GetBucketLogging
              - s3:PutBucketLogging
              - s3:GetEncryptionConfiguration
              - s3:PutEncryptionConfiguration
              - s3:GetBucketPublicAccessBlock
              - s3:PutBucketPublicAccessBlock
              - s3:GetLifecycleConfiguration
              - s3:PutLifecycleConfiguration
              - s3:GetBucketLocation
              - s3:GetBucketTagging
              - s3:PutBucketTagging
              - s3:GetBucketNotification
              - s3:PutBucketNotification
              - s3:GetBucketObjectLockConfiguration
              - s3:PutBucketObjectLockConfiguration
              - s3:ListBucket
              - s3:GetObject
              - s3:PutObject
              - s3:DeleteObject
              - s3:GetBucketOwnershipControls
              - s3:PutBucketOwnershipControls
            Resource:
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-security-*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-security-*/*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-config-*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-config-*/*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-cloudtrail-*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-cloudtrail-*/*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-guardduty-*
              - !Sub arn:${AWS::Partition}:s3:::${AWS::AccountId}-guardduty-*/*

          # ── KMS — encryption keys for security services ─
          - Sid: KMSManagement
            Effect: Allow
            Action:
              - kms:CreateKey
              - kms:DescribeKey
              - kms:GetKeyPolicy
              - kms:GetKeyRotationStatus
              - kms:ListResourceTags
              - kms:PutKeyPolicy
              - kms:EnableKeyRotation
              - kms:DisableKeyRotation
              - kms:ScheduleKeyDeletion
              - kms:CancelKeyDeletion
              - kms:TagResource
              - kms:UntagResource
              - kms:CreateAlias
              - kms:DeleteAlias
              - kms:UpdateAlias
              - kms:ListAliases
              - kms:CreateGrant
              - kms:ListGrants
              - kms:RevokeGrant
              - kms:Encrypt
              - kms:Decrypt
              - kms:GenerateDataKey
            Resource: "*"

          # ── SNS — notification topics for findings/alerts ─
          - Sid: SNSTopics
            Effect: Allow
            Action:
              - sns:CreateTopic
              - sns:DeleteTopic
              - sns:GetTopicAttributes
              - sns:SetTopicAttributes
              - sns:Subscribe
              - sns:Unsubscribe
              - sns:ListSubscriptionsByTopic
              - sns:TagResource
              - sns:UntagResource
              - sns:ListTagsForResource
            Resource:
              - !Sub arn:${AWS::Partition}:sns:*:${AWS::AccountId}:security-*
              - !Sub arn:${AWS::Partition}:sns:*:${AWS::AccountId}:config-*
              - !Sub arn:${AWS::Partition}:sns:*:${AWS::AccountId}:guardduty-*
              - !Sub arn:${AWS::Partition}:sns:*:${AWS::AccountId}:securityhub-*

          # ── CloudWatch Logs — for CloudTrail log groups ─
          - Sid: CloudWatchLogs
            Effect: Allow
            Action:
              - logs:CreateLogGroup
              - logs:DeleteLogGroup
              - logs:DescribeLogGroups
              - logs:PutRetentionPolicy
              - logs:DeleteRetentionPolicy
              - logs:TagLogGroup
              - logs:UntagLogGroup
              - logs:ListTagsLogGroup
              - logs:TagResource
              - logs:UntagResource
              - logs:ListTagsForResource
            Resource:
              - !Sub arn:${AWS::Partition}:logs:*:${AWS::AccountId}:log-group:/aws/cloudtrail/*
              - !Sub arn:${AWS::Partition}:logs:*:${AWS::AccountId}:log-group:/aws/config/*
              - !Sub arn:${AWS::Partition}:logs:*:${AWS::AccountId}:log-group:security-*

          # ── EventBridge — for security event routing ─
          - Sid: EventBridge
            Effect: Allow
            Action:
              - events:PutRule
              - events:DeleteRule
              - events:DescribeRule
              - events:EnableRule
              - events:DisableRule
              - events:PutTargets
              - events:RemoveTargets
              - events:ListTargetsByRule
              - events:TagResource
              - events:UntagResource
              - events:ListTagsForResource
            Resource:
              - !Sub arn:${AWS::Partition}:events:*:${AWS::AccountId}:rule/security-*
              - !Sub arn:${AWS::Partition}:events:*:${AWS::AccountId}:rule/guardduty-*
              - !Sub arn:${AWS::Partition}:events:*:${AWS::AccountId}:rule/securityhub-*
              - !Sub arn:${AWS::Partition}:events:*:${AWS::AccountId}:rule/config-*

  # ──────────────────────────────────────────
  # 3. IAM Managed Policy — Terraform State Access
  #    Note: AWS::IAM::ManagedPolicy does not
  #    support Tags in CloudFormation.
  # ──────────────────────────────────────────
  TerraformStateAccessPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName: TerraformStateAccess
      Description: >
        Grants read/write access to the Terraform remote state S3 bucket,
        the DynamoDB lock table, and the state encryption KMS key.
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: S3StateBucket
            Effect: Allow
            Action:
              - s3:GetObject
              - s3:PutObject
              - s3:DeleteObject
              - s3:ListBucket
              - s3:GetBucketLocation
              - s3:GetBucketVersioning
            Resource:
              - !GetAtt TfStateBucket.Arn
              - !Sub "${TfStateBucket.Arn}/*"
          - Sid: DynamoDBLockTable
            Effect: Allow
            Action:
              - dynamodb:GetItem
              - dynamodb:PutItem
              - dynamodb:DeleteItem
              - dynamodb:DescribeTable
            Resource:
              - !GetAtt TfLockTable.Arn
          - Sid: KMSStateKey
            Effect: Allow
            Action:
              - kms:Decrypt
              - kms:Encrypt
              - kms:GenerateDataKey
              - kms:DescribeKey
            Resource:
              - !GetAtt TfStateKmsKey.Arn

  # ──────────────────────────────────────────
  # 4. IAM Role — NonProd
  # ──────────────────────────────────────────
  NonProdDeployRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: !Sub github-actions-${NonProdEnvironment}
      MaxSessionDuration: 3600
      PermissionsBoundary:
        !If [HasPermissionsBoundary, !Ref PermissionsBoundaryArn, !Ref "AWS::NoValue"]
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Federated: !Ref GitHubOIDCProvider
            Action: sts:AssumeRoleWithWebIdentity
            Condition:
              StringEquals:
                token.actions.githubusercontent.com:aud: sts.amazonaws.com
              StringLike:
                token.actions.githubusercontent.com:sub:
                  - !Sub repo:${GitHubOrg}/${GitHubRepo}:environment:${NonProdEnvironment}
      ManagedPolicyArns:
        - !Ref SecurityToolingDeployPolicy
        - !Ref TerraformStateAccessPolicy
      Tags:
        - Key: environment
          Value: !Ref NonProdEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  # ──────────────────────────────────────────
  # 5. IAM Role — Prod
  # ──────────────────────────────────────────
  ProdDeployRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName: !Sub github-actions-${ProdEnvironment}
      MaxSessionDuration: 3600
      PermissionsBoundary:
        !If [HasPermissionsBoundary, !Ref PermissionsBoundaryArn, !Ref "AWS::NoValue"]
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Federated: !Ref GitHubOIDCProvider
            Action: sts:AssumeRoleWithWebIdentity
            Condition:
              StringEquals:
                token.actions.githubusercontent.com:aud: sts.amazonaws.com
              StringLike:
                token.actions.githubusercontent.com:sub:
                  - !Sub repo:${GitHubOrg}/${GitHubRepo}:environment:${ProdEnvironment}
      ManagedPolicyArns:
        - !Ref SecurityToolingDeployPolicy
        - !Ref TerraformStateAccessPolicy
      Tags:
        - Key: environment
          Value: !Ref ProdEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  # ──────────────────────────────────────────
  # 6a. KMS CMK for Terraform State Encryption
  # ──────────────────────────────────────────
  TfStateKmsKey:
    Type: AWS::KMS::Key
    Properties:
      Description: CMK for Terraform state bucket encryption
      EnableKeyRotation: true
      KeyPolicy:
        Version: "2012-10-17"
        Statement:
          - Sid: AllowRootAccountFullAccess
            Effect: Allow
            Principal:
              AWS: !Sub arn:${AWS::Partition}:iam::${AWS::AccountId}:root
            Action: kms:*
            Resource: "*"
      Tags:
        - Key: environment
          Value: !Ref TagEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  TfStateKmsKeyAlias:
    Type: AWS::KMS::Alias
    Properties:
      AliasName: alias/terraform-state
      TargetKeyId: !Ref TfStateKmsKey

  # ──────────────────────────────────────────
  # 6b. S3 Access Logging Bucket
  # ──────────────────────────────────────────
  TfStateAccessLogsBucket:
    Type: AWS::S3::Bucket
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
    Properties:
      BucketName: !Sub "${TfStateBucketName}-access-logs"
      ObjectLockEnabled: true
      ObjectLockConfiguration:
        ObjectLockEnabled: Enabled
        Rule:
          DefaultRetention:
            Mode: GOVERNANCE
            Days: 365
      OwnershipControls:
        Rules:
          - ObjectOwnership: BucketOwnerPreferred
      VersioningConfiguration:
        Status: Enabled
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: aws:kms
              KMSMasterKeyID: !GetAtt TfStateKmsKey.Arn
            BucketKeyEnabled: true
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      LifecycleConfiguration:
        Rules:
          - Id: ExpireOldLogs
            Status: Enabled
            ExpirationInDays: 365
      Tags:
        - Key: environment
          Value: !Ref TagEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  TfStateAccessLogsBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket: !Ref TfStateAccessLogsBucket
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: S3ServerAccessLogsPolicy
            Effect: Allow
            Principal:
              Service: logging.s3.amazonaws.com
            Action: s3:PutObject
            Resource: !Sub "${TfStateAccessLogsBucket.Arn}/*"
            Condition:
              ArnLike:
                aws:SourceArn: !Sub arn:${AWS::Partition}:s3:::${TfStateBucketName}
              StringEquals:
                aws:SourceAccount: !Ref AWS::AccountId
          - Sid: DenyInsecureTransport
            Effect: Deny
            Principal: "*"
            Action: s3:*
            Resource:
              - !GetAtt TfStateAccessLogsBucket.Arn
              - !Sub "${TfStateAccessLogsBucket.Arn}/*"
            Condition:
              Bool:
                aws:SecureTransport: "false"

  # ──────────────────────────────────────────
  # 6c. Terraform State — S3 Bucket
  # ──────────────────────────────────────────
  TfStateBucket:
    Type: AWS::S3::Bucket
    DependsOn: TfStateAccessLogsBucketPolicy
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
    Properties:
      BucketName: !Ref TfStateBucketName
      OwnershipControls:
        Rules:
          - ObjectOwnership: BucketOwnerEnforced
      VersioningConfiguration:
        Status: Enabled
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: aws:kms
              KMSMasterKeyID: !GetAtt TfStateKmsKey.Arn
            BucketKeyEnabled: true
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      LoggingConfiguration:
        DestinationBucketName: !Ref TfStateAccessLogsBucket
        LogFilePrefix: state-bucket-logs/
      LifecycleConfiguration:
        Rules:
          - Id: ExpireNoncurrentVersions
            Status: Enabled
            NoncurrentVersionExpiration:
              NoncurrentDays: 90
      Tags:
        - Key: environment
          Value: !Ref TagEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

  TfStateBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket: !Ref TfStateBucket
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: DenyInsecureTransport
            Effect: Deny
            Principal: "*"
            Action: s3:*
            Resource:
              - !GetAtt TfStateBucket.Arn
              - !Sub "${TfStateBucket.Arn}/*"
            Condition:
              Bool:
                aws:SecureTransport: "false"
          - Sid: DenyOldTLSVersions
            Effect: Deny
            Principal: "*"
            Action: s3:*
            Resource:
              - !GetAtt TfStateBucket.Arn
              - !Sub "${TfStateBucket.Arn}/*"
            Condition:
              NumericLessThan:
                s3:TlsVersion: "1.2"
          - Sid: DenyNonKMSEncryptedUploads
            Effect: Deny
            Principal: "*"
            Action: s3:PutObject
            Resource: !Sub "${TfStateBucket.Arn}/*"
            Condition:
              StringNotEquals:
                s3:x-amz-server-side-encryption: aws:kms
          - Sid: DenyWrongKMSKey
            Effect: Deny
            Principal: "*"
            Action: s3:PutObject
            Resource: !Sub "${TfStateBucket.Arn}/*"
            Condition:
              StringNotEqualsIfExists:
                s3:x-amz-server-side-encryption-aws-kms-key-id: !GetAtt TfStateKmsKey.Arn

  # ──────────────────────────────────────────
  # 7. Terraform State — DynamoDB Lock Table
  # ──────────────────────────────────────────
  TfLockTable:
    Type: AWS::DynamoDB::Table
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
    Properties:
      TableName: !Ref TfLockTableName
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: LockID
          AttributeType: S
      KeySchema:
        - AttributeName: LockID
          KeyType: HASH
      SSESpecification:
        SSEEnabled: true
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
      Tags:
        - Key: environment
          Value: !Ref TagEnvironment
        - Key: project_name
          Value: !Ref TagProjectName
        - Key: application_name
          Value: !Ref TagApplicationName
        - Key: charge_number
          Value: !Ref TagChargeNumber
        - Key: account_id
          Value: !Ref TagAccountId
        - Key: org_id
          Value: !Ref TagOrgId
        - Key: business_unit
          Value: !Ref TagBusinessUnit
        - Key: business_area
          Value: !Ref TagBusinessArea
        - Key: responsible_team
          Value: !Ref TagResponsibleTeam
        - Key: financial_category
          Value: !Ref TagFinancialCategory
        - Key: confidentiality
          Value: !Ref TagConfidentiality
        - Key: export_controlled
          Value: !Ref TagExportControlled
        - Key: cui_classification
          Value: !Ref TagCuiClassification
        - Key: compliance
          Value: !Ref TagCompliance
        - Key: expected_eol_date
          Value: !Ref TagExpectedEolDate
        - Key: business_tier
          Value: !Ref TagBusinessTier
        - Key: security_tier
          Value: !Ref TagSecurityTier
        - Key: landingzone_name
          Value: !Ref TagLandingzoneName
        - Key: business_owner
          Value: !Ref TagBusinessOwner
        - Key: tech_owner
          Value: !Ref TagTechOwner
        - Key: source_github_project
          Value: !Ref TagSourceGithubProject
        - Key: terraform_managed
          Value: !Ref TagTerraformManaged

