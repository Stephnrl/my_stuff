terraform {
  required_version = ">= 1.3"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    # The AWSCC provider is auto-generated from the AWS CloudFormation Cloud
    # Control API, giving same-day access to new AWS resources like Security
    # Hub v2 that are not yet available in the standard AWS provider.
    # https://registry.terraform.io/providers/hashicorp/awscc
    awscc = {
      source  = "hashicorp/awscc"
      version = ">= 1.0"
    }
  }
}
