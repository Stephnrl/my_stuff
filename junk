KubePodInventory
| where TimeGenerated between (datetime(2026-03-19T17:40:00Z) .. datetime(2026-03-20T07:00:00Z))
| join kind=inner MaliciousLogs on $left.Name == $right.Name
| project TimeGenerated, Name, LogEntry, PodLabel
